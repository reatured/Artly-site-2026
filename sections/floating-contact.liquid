{% assign floating_contact_form_id = 'FloatingContactForm-' | append: section.id %}
{% assign floating_contact_return_to = request.path | default: routes.root_url | append: '#floating-contact' %}
{% assign floating_contact_is_artly_ai = false %}
{% if template.name == 'page' and template.suffix == 'artly-ai' %}
  {% assign floating_contact_is_artly_ai = true %}
{% endif %}
{% assign floating_contact_trigger_text = 'sections.floating_contact.trigger' | t %}
{% assign floating_contact_heading = 'sections.floating_contact.heading' | t %}
{% assign floating_contact_text = 'sections.floating_contact.text' | t %}
{% assign floating_contact_submit = 'sections.floating_contact.submit' | t %}
{% assign floating_contact_success = 'sections.floating_contact.success' | t %}
{% if floating_contact_is_artly_ai %}
  {% assign floating_contact_trigger_text = 'sections.floating_contact.trigger' | t %}
  {% assign floating_contact_heading = 'Talk with Artly AI' %}
  {% assign floating_contact_text = 'Tell us what you want to automate, and our team will follow up about contact or demo next steps.' %}
  {% assign floating_contact_submit = 'Send request' %}
  {% assign floating_contact_success = 'Thanks. The Artly AI team will follow up about your request.' %}
{% endif %}

<floating-contact class="floating-contact" data-floating-contact>
  <section id="floating-contact" class="floating-contact__section">
    <details class="floating-contact__details">
      <summary class="floating-contact__summary">
        <span class="floating-contact__summary-label floating-contact__summary-label--closed">
          {{- floating_contact_trigger_text -}}
        </span>
        <span class="floating-contact__summary-label floating-contact__summary-label--open visually-hidden">
          {{- 'sections.floating_contact.close' | t -}}
        </span>
        <span class="floating-contact__summary-close" aria-hidden="true">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </summary>

      <div
        class="floating-contact__panel"
        id="FloatingContactPanel-{{ section.id }}"
        role="region"
        aria-labelledby="FloatingContactHeading-{{ section.id }}"
      >
        <div class="floating-contact__header">
          <h2 class="floating-contact__heading" id="FloatingContactHeading-{{ section.id }}">
            {{- floating_contact_heading -}}
          </h2>
          <p class="floating-contact__text">
            {{- floating_contact_text -}}
          </p>
        </div>

        {% if floating_contact_is_artly_ai %}
          {%- form 'contact', id: floating_contact_form_id, class: 'floating-contact__form', return_to: floating_contact_return_to -%}
            <input
              name="contact[tags]"
              type="hidden"
              value="artly-ai-contact,floating-contact"
            >
            <input
              name="contact[request_type]"
              type="hidden"
              value="Artly AI contact or demo request"
            >
            <input
              name="contact[body]"
              type="hidden"
              value="Artly AI contact or demo request from the floating contact panel."
            >

            {%- if form.errors and form.id == floating_contact_form_id -%}
              <div
                class="floating-contact__message floating-contact__message--error"
                id="FloatingContactError-{{ section.id }}"
                tabindex="-1"
                data-floating-contact-message
              >
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            {%- if form.posted_successfully? and form.id == floating_contact_form_id -%}
              <p
                class="floating-contact__message floating-contact__message--success"
                tabindex="-1"
                data-floating-contact-message
              >
                {{- floating_contact_success -}}
              </p>
            {%- endif -%}

            <div class="floating-contact__field">
              <label class="floating-contact__label" for="FloatingContactName-{{ section.id }}">
                {{- 'blocks.contact_form.name' | t -}}
              </label>
              <input
                class="floating-contact__input"
                id="FloatingContactName-{{ section.id }}"
                type="text"
                name="contact[name]"
                autocomplete="name"
                value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}"
                required
              >
            </div>

            <div class="floating-contact__field">
              <label class="floating-contact__label" for="FloatingContactEmail-{{ section.id }}">
                {{- 'blocks.contact_form.email' | t -}}
              </label>
              <input
                class="floating-contact__input"
                id="FloatingContactEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
                required
                aria-required="true"
                {% if form.errors contains 'email' and form.id == floating_contact_form_id %}
                  aria-invalid="true"
                  aria-describedby="FloatingContactError-{{ section.id }}"
                {% endif %}
              >
            </div>

            <button class="button floating-contact__submit" type="submit">
              {{- floating_contact_submit -}}
            </button>

            <p
              class="floating-contact__submit-status"
              data-floating-contact-status
              data-sending-text="{{ 'blocks.contact_form.sending' | t | escape }}"
              aria-live="polite"
              hidden
            >
              {{- 'blocks.contact_form.sending' | t -}}
            </p>
          {%- endform -%}
        {% else %}
          {%- form 'customer', id: floating_contact_form_id, class: 'floating-contact__form', return_to: floating_contact_return_to -%}
            <input
              name="contact[tags]"
              type="hidden"
              value="newsletter,floating-contact"
            >

            {%- if form.errors and form.id == floating_contact_form_id -%}
              <div
                class="floating-contact__message floating-contact__message--error"
                id="FloatingContactError-{{ section.id }}"
                tabindex="-1"
                data-floating-contact-message
              >
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            {%- if form.posted_successfully? and form.id == floating_contact_form_id -%}
              <p
                class="floating-contact__message floating-contact__message--success"
                tabindex="-1"
                data-floating-contact-message
              >
                {{- floating_contact_success -}}
              </p>
            {%- endif -%}

            <div class="floating-contact__field">
              <label class="floating-contact__label" for="FloatingContactName-{{ section.id }}">
                {{- 'blocks.contact_form.name' | t -}}
              </label>
              <input
                class="floating-contact__input"
                id="FloatingContactName-{{ section.id }}"
                type="text"
                name="contact[first_name]"
                autocomplete="name"
                value="{% if customer %}{{ customer.first_name }}{% endif %}"
                required
              >
            </div>

            <div class="floating-contact__field">
              <label class="floating-contact__label" for="FloatingContactEmail-{{ section.id }}">
                {{- 'blocks.contact_form.email' | t -}}
              </label>
              <input
                class="floating-contact__input"
                id="FloatingContactEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                required
                aria-required="true"
                {% if form.errors contains 'email' and form.id == floating_contact_form_id %}
                  aria-invalid="true"
                  aria-describedby="FloatingContactError-{{ section.id }}"
                {% endif %}
              >
            </div>

            <button class="button floating-contact__submit" type="submit">
              {{- floating_contact_submit -}}
            </button>

            <p
              class="floating-contact__submit-status"
              data-floating-contact-status
              data-sending-text="{{ 'blocks.contact_form.sending' | t | escape }}"
              aria-live="polite"
              hidden
            >
              {{- 'blocks.contact_form.sending' | t -}}
            </p>
          {%- endform -%}
        {% endif %}
      </div>
    </details>
  </section>
</floating-contact>

{% stylesheet %}
  .floating-contact {
    display: block;
    position: fixed;
    right: max(16px, env(safe-area-inset-right));
    bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 40;
    width: min(360px, calc(100vw - 32px));
    pointer-events: none;
  }

  .floating-contact__details {
    position: relative;
    display: flex;
    justify-content: flex-end;
    pointer-events: auto;
  }

  .floating-contact__summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 112px;
    min-height: 44px;
    padding: 0 18px;
    color: var(--color-primary-button-text);
    background: var(--color-primary-button-background);
    border-radius: 999px;
    box-shadow: 0 14px 34px rgb(0 0 0 / 18%);
    cursor: pointer;
    user-select: none;
    list-style: none;
    font: var(--font-body--weight) var(--font-size--sm) / 1 var(--font-body--family);
    transition:
      transform var(--animation-speed) var(--animation-easing),
      box-shadow var(--animation-speed) var(--animation-easing);
  }

  .floating-contact__summary::-webkit-details-marker {
    display: none;
  }

  .floating-contact__summary:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 42px rgb(0 0 0 / 20%);
  }

  .floating-contact__summary:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .floating-contact__summary-close {
    display: none;
    width: 18px;
    height: 18px;
  }

  .floating-contact__summary-close svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .floating-contact__details[open] .floating-contact__summary {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 1;
    min-width: 36px;
    width: 36px;
    min-height: 36px;
    padding: 0;
    color: var(--color-foreground);
    background: transparent;
    border-radius: 50%;
    box-shadow: none;
  }

  .floating-contact__details[open] .floating-contact__summary:hover {
    transform: none;
    background: rgb(0 0 0 / 6%);
  }

  .floating-contact__details[open] .floating-contact__summary-label--closed {
    display: none;
  }

  .floating-contact__summary-label--open {
    display: none;
  }

  .floating-contact__details[open] .floating-contact__summary-label--open {
    display: block;
  }

  .floating-contact__details[open] .floating-contact__summary-close {
    display: block;
  }

  .floating-contact__panel {
    width: 100%;
    padding: 22px;
    color: var(--color-foreground);
    background: var(--color-background);
    border: 1px solid rgb(var(--color-foreground-rgb) / 12%);
    border-radius: 8px;
    box-shadow: 0 20px 56px rgb(0 0 0 / 22%);
  }

  .floating-contact__header {
    padding-right: 42px;
    margin-bottom: 16px;
  }

  .floating-contact__heading {
    margin: 0 0 6px;
    font: var(--font-heading--weight) var(--font-size--lg) / 1.15 var(--font-heading--family);
    letter-spacing: 0;
  }

  .floating-contact__text {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 72%);
    font-size: var(--font-size--sm);
    line-height: 1.45;
  }

  .floating-contact__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .floating-contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .floating-contact__label {
    font-size: var(--font-size--xs);
    line-height: 1.2;
  }

  .floating-contact__input {
    width: 100%;
    min-height: 44px;
    padding: 11px 13px;
    color: var(--color-input-text);
    background: var(--color-input-background);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    border-radius: var(--style-border-radius-inputs);
    font: inherit;
  }

  .floating-contact__input:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .floating-contact__submit {
    width: 100%;
    min-height: 44px;
    margin-top: 2px;
  }

  .floating-contact__form[data-submitting='true'] .floating-contact__submit {
    position: relative;
    pointer-events: none;
    opacity: 0.82;
  }

  .floating-contact__form[data-submitting='true'] .floating-contact__submit::before {
    content: '';
    position: absolute;
    inset-inline-start: var(--button-padding-inline);
    top: 50%;
    translate: 0 -50%;
    width: 1em;
    height: 1em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: floating-contact-submit-spin 700ms linear infinite;
  }

  .floating-contact__submit-status {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 72%);
    font-size: var(--font-size--sm);
    line-height: 1.35;
  }

  .floating-contact__message {
    margin: 0;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: var(--font-size--sm);
    line-height: 1.35;
  }

  .floating-contact__message ul {
    margin: 0;
    padding-left: 18px;
  }

  .floating-contact__message--error {
    color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 10%, transparent);
  }

  .floating-contact__message--success {
    color: var(--color-foreground);
    background: rgb(var(--color-foreground-rgb) / 8%);
  }

  @media screen and (max-width: 749px) {
    .floating-contact {
      right: max(12px, env(safe-area-inset-right));
      bottom: max(12px, env(safe-area-inset-bottom));
      width: min(340px, calc(100vw - 24px));
    }

    .floating-contact__panel {
      padding: 20px;
    }

    body:has(.artly-ai-l1) .floating-contact:not(:has(.floating-contact__details[open])) {
      right: max(4px, calc(env(safe-area-inset-right) + 4px));
      bottom: max(112px, calc(env(safe-area-inset-bottom) + 112px));
      width: auto;
      pointer-events: auto;
    }

    body:has(.artly-ai-l1) .floating-contact__details:not([open]) .floating-contact__summary {
      width: 24px;
      min-width: 24px;
      min-height: 82px;
      padding: 8px 2px;
      border-radius: 999px 0 0 999px;
      font-size: 0.64rem;
      letter-spacing: 0.08em;
      box-shadow: 0 10px 22px rgb(0 0 0 / 16%);
      text-transform: uppercase;
      writing-mode: vertical-rl;
    }

    body:has(.artly-ai-l1) .floating-contact__details:not([open]) .floating-contact__summary-label--closed {
      max-width: none;
      max-height: 68px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    body:has(.artly-ai-l1) .floating-contact.floating-contact--mobile-hero-hidden:not(:has(.floating-contact__details[open])) {
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
      transform: translateY(8px);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .floating-contact__panel {
      animation: floating-contact-panel-in var(--animation-speed) var(--animation-easing);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-contact__form[data-submitting='true'] .floating-contact__submit::before {
      animation: none;
    }
  }

  @keyframes floating-contact-panel-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes floating-contact-submit-spin {
    to {
      transform: rotate(360deg);
    }
  }
{% endstylesheet %}

{% javascript %}
  class FloatingContact extends HTMLElement {
    connectedCallback() {
      const details = this.querySelector('details');
      const message = this.querySelector('[data-floating-contact-message]');
      const form = this.querySelector('.floating-contact__form');

      if (form instanceof HTMLFormElement && form.dataset.submitStateInitialized !== 'true') {
        form.dataset.submitStateInitialized = 'true';
        form.addEventListener('submit', () => {
          if (!form.checkValidity()) return;

          const button = form.querySelector('.floating-contact__submit');
          const status = form.querySelector('[data-floating-contact-status]');

          form.dataset.submitting = 'true';

          if (button instanceof HTMLButtonElement) {
            button.disabled = true;
            button.setAttribute('aria-busy', 'true');
          }

          if (status instanceof HTMLElement) {
            status.hidden = false;
            status.textContent = status.dataset.sendingText || '';
          }
        });
      }

      if (!(details instanceof HTMLDetailsElement)) return;

      this.setupArtlyAiMobileGuard(details);

      if (!(message instanceof HTMLElement)) return;

      details.open = true;
      requestAnimationFrame(() => message.focus({ preventScroll: true }));
    }

    setupArtlyAiMobileGuard(details) {
      if (!(details instanceof HTMLDetailsElement)) return;
      if (this.dataset.mobileGuardInitialized === 'true') return;
      if (!document.querySelector('.artly-ai-l1')) return;

      this.dataset.mobileGuardInitialized = 'true';

      const hero = document.querySelector('.artly-ai-l1-hero');
      const mediaQuery = window.matchMedia('(max-width: 749px)');
      const updateState = () => {
        const heroRect = hero ? hero.getBoundingClientRect() : null;
        const heroInView = Boolean(heroRect && heroRect.bottom > 96 && heroRect.top < window.innerHeight - 96);
        const shouldHide = mediaQuery.matches && !details.open && heroInView;
        this.classList.toggle('floating-contact--mobile-hero-hidden', shouldHide);
      };

      updateState();
      details.addEventListener('toggle', updateState);
      window.addEventListener('scroll', updateState, { passive: true });
      window.addEventListener('resize', updateState);

      if (mediaQuery.addEventListener) {
        mediaQuery.addEventListener('change', updateState);
      } else if (mediaQuery.addListener) {
        mediaQuery.addListener(updateState);
      }
    }
  }

  if (!customElements.get('floating-contact')) {
    customElements.define('floating-contact', FloatingContact);
  }

  window.addEventListener('pageshow', () => {
    document.querySelectorAll('.floating-contact__form[data-submitting="true"]').forEach((form) => {
      const button = form.querySelector('.floating-contact__submit');
      const status = form.querySelector('[data-floating-contact-status]');

      delete form.dataset.submitting;

      if (button instanceof HTMLButtonElement) {
        button.disabled = false;
        button.removeAttribute('aria-busy');
      }

      if (status instanceof HTMLElement) {
        status.hidden = true;
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Floating contact",
  "class": "floating-contact-section"
}
{% endschema %}
