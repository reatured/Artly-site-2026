<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{% assign is_artly_ai_page = false %}
{% if template.suffix == 'artly-ai' %}
  {% assign is_artly_ai_page = true %}
{% elsif template.name == 'page.artly-ai' %}
  {% assign is_artly_ai_page = true %}
{% endif %}
{% assign trusted_by_section_width = section.settings.section_width %}
{% if is_artly_ai_page %}
  {% assign trusted_by_section_width = 'full-width' %}
{% endif %}
{% assign strip_alignment = 'flex-start' %}
{% case section.settings.alignment %}
  {% when 'center' %}
    {% assign strip_alignment = 'center' %}
  {% when 'right' %}
    {% assign strip_alignment = 'flex-end' %}
{% endcase %}

<section
  class="
    section
    section--{{ trusted_by_section_width }}
    spacing-style
    color-{{ section.settings.color_scheme }}
    trusted-by-logo-strip
    trusted-by-logo-strip--{{ section.settings.strip_mode }}
    trusted-by-logo-strip--{{ section.settings.alignment }}
    {% if is_artly_ai_page %}artly-system artly-ai-l1 trusted-by-logo-strip--artly-ai{% endif %}
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --trusted-by-logo-height: {{ section.settings.logo_height }}px;
    --trusted-by-logo-gap: {{ section.settings.logo_gap }}px;
    --trusted-by-logo-alignment: {{ strip_alignment }};
  "
  {{ section.shopify_attributes }}
>
  {% if is_artly_ai_page %}
    <div class="artly-ai__rail trusted-by-logo-strip__rail">
  {% endif %}

  {% if section.settings.show_heading and section.settings.heading != blank %}
    <h2 class="trusted-by-logo-strip__heading">{{ section.settings.heading | escape }}</h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="trusted-by-logo-strip__viewport">
      <ul
        class="trusted-by-logo-strip__list"
        role="list"
        aria-label="{{ section.settings.heading | default: 'Trusted by logos' | escape }}"
      >
        {% content_for 'blocks' %}
      </ul>
    </div>
  {% endif %}

  {% if is_artly_ai_page %}
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .trusted-by-logo-strip {
    --trusted-by-logo-height: 32px;
    --trusted-by-logo-gap: 22px;
    --trusted-by-logo-alignment: flex-start;
    display: grid;
    gap: var(--trusted-by-logo-gap);
  }

.trusted-by-logo-strip > .artly-ai__rail {
  display: grid;
  gap: var(--trusted-by-logo-gap);
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
}

.trusted-by-logo-strip--artly-ai {
  --trusted-by-logo-gap: clamp(14px, 2vw, 20px);
  position: relative;
  isolation: isolate;
  padding-block: clamp(42px, 6vw, 72px);
  background:
    radial-gradient(circle at 12% 0%, rgba(139, 209, 224, 0.2), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 251, 0.96));
  border-block: 1px solid rgba(106, 118, 128, 0.14);
}

.trusted-by-logo-strip--artly-ai > .artly-ai__rail {
  width: var(--artly-ai-rail, var(--artly-rail-width, min(1180px, calc(100% - 32px))));
  max-width: var(--artly-ai-rail, var(--artly-rail-width, min(1180px, calc(100% - 32px))));
  margin-inline: auto;
  justify-self: center;
  gap: clamp(22px, 3vw, 34px);
  padding: clamp(22px, 3vw, 34px);
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(106, 118, 128, 0.16);
  border-radius: 8px;
  box-shadow: 0 22px 70px rgba(17, 24, 39, 0.08);
}

.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__heading {
  color: var(--artly-ink);
  font-size: clamp(1.25rem, 2vw, 1.8rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__viewport {
  padding: clamp(4px, 1vw, 10px);
  background:
    linear-gradient(90deg, rgba(185, 220, 229, 0.18), transparent 16%, transparent 84%, rgba(185, 220, 229, 0.18)),
    rgba(250, 252, 253, 0.82);
  border: 1px solid rgba(106, 118, 128, 0.12);
  border-radius: 8px;
}

.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__list {
  gap: var(--trusted-by-logo-gap);
}

.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__link,
.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__logo {
  min-height: 52px;
  padding: 0.55rem 0.8rem;
  background: rgba(255, 255, 255, 0.86);
  border: 1px solid rgba(106, 118, 128, 0.14);
  border-radius: 8px;
  box-shadow: 0 10px 28px rgba(17, 24, 39, 0.05);
}

.trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__image {
  height: clamp(30px, 3vw, 38px);
  filter: grayscale(0.12) saturate(0.96) contrast(1.08);
  opacity: 0.92;
}

@media screen and (max-width: 749px) {
  .trusted-by-logo-strip--artly-ai {
    padding-block: 38px;
  }

  .trusted-by-logo-strip--artly-ai > .artly-ai__rail {
    gap: 18px;
    padding: 18px 14px;
  }

  .trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__list {
    justify-content: center;
  }

  .trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__link,
  .trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__logo {
    min-height: 48px;
    max-width: 9.75rem;
    padding: 0.45rem 0.62rem;
  }

  .trusted-by-logo-strip--artly-ai .trusted-by-logo-strip__image {
    height: clamp(26px, 7vw, 34px);
  }
}

  .trusted-by-logo-strip__heading {
    margin: 0;
  }

  .trusted-by-logo-strip--left .trusted-by-logo-strip__heading {
    text-align: left;
  }

  .trusted-by-logo-strip--center .trusted-by-logo-strip__heading {
    text-align: center;
  }

  .trusted-by-logo-strip--right .trusted-by-logo-strip__heading {
    text-align: right;
  }

  .trusted-by-logo-strip__viewport {
    width: 100%;
  }

  .trusted-by-logo-strip__list {
    --list-top-bottom-padding: 0px;
    margin: 0;
    padding: var(--list-top-bottom-padding) 0;
    list-style: none;
    display: flex;
    gap: var(--trusted-by-logo-gap);
    align-items: center;
    scroll-padding-inline: var(--trusted-by-logo-gap);
  }

  .trusted-by-logo-strip__item {
    flex: 0 0 auto;
  }

  .trusted-by-logo-strip--static .trusted-by-logo-strip__list {
    flex-wrap: wrap;
    justify-content: var(--trusted-by-logo-alignment, flex-start);
  }

  .trusted-by-logo-strip--scroll .trusted-by-logo-strip__list {
    flex-wrap: nowrap;
    justify-content: flex-start;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 0.25rem;
  }

  .trusted-by-logo-strip--scroll .trusted-by-logo-strip__list::-webkit-scrollbar {
    display: none;
  }

  .trusted-by-logo-strip__item {
    scroll-snap-align: center;
  }

  @media screen and (max-width: 749px) {
    .trusted-by-logo-strip--scroll .trusted-by-logo-strip__list {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 0.25rem;
      -webkit-overflow-scrolling: touch;
    }

    .trusted-by-logo-strip--scroll .trusted-by-logo-strip__list::-webkit-scrollbar {
      display: none;
    }

    .trusted-by-logo-strip--static .trusted-by-logo-strip__list {
      flex-wrap: wrap;
      justify-content: var(--trusted-by-logo-alignment, flex-start);
      overflow-x: visible;
      scroll-snap-type: none;
    }

    .trusted-by-logo-strip__item {
      flex: 0 0 auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trusted by logo strip",
  "class": "trusted-by-logo-strip-section",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section content"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted By"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "strip_mode",
      "label": "Strip mode",
      "options": [
        {
          "value": "static",
          "label": "Static"
        },
        {
          "value": "scroll",
          "label": "Scroll"
        }
      ],
      "default": "scroll"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Default logo height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Gap",
      "min": 4,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open logo links in new tab by default",
      "default": false
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "trusted-by-logo"
    }
  ],
  "presets": [
    {
      "name": "Trusted by logo strip",
      "category": "Trust and proof",
      "settings": {
        "show_heading": true,
        "heading": "Trusted By",
        "alignment": "center",
        "strip_mode": "scroll",
        "logo_height": 32,
        "logo_gap": 22,
        "open_in_new_tab": false,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 28,
        "padding-block-end": 28
      },
      "blocks": {
        "logo-a": {
          "type": "trusted-by-logo",
          "settings": {
            "logo_name": "Trusted Brand 1",
            "logo_alt_text": "Trusted Brand 1 logo",
            "display_height": 32,
            "open_in_new_tab": "inherit"
          }
        },
        "logo-b": {
          "type": "trusted-by-logo",
          "settings": {
            "logo_name": "Trusted Brand 2",
            "logo_alt_text": "Trusted Brand 2 logo",
            "display_height": 32,
            "open_in_new_tab": "inherit"
          }
        },
        "logo-c": {
          "type": "trusted-by-logo",
          "settings": {
            "logo_name": "Trusted Brand 3",
            "logo_alt_text": "Trusted Brand 3 logo",
            "display_height": 32,
            "open_in_new_tab": "inherit"
          }
        },
        "logo-d": {
          "type": "trusted-by-logo",
          "settings": {
            "logo_name": "Trusted Brand 4",
            "logo_alt_text": "Trusted Brand 4 logo",
            "display_height": 32,
            "open_in_new_tab": "inherit"
          }
        }
      },
      "block_order": ["logo-a", "logo-b", "logo-c", "logo-d"]
    }
  ]
}
{% endschema %}
