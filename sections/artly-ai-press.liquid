<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style artly-system artly-ai-l1"
  aria-labelledby="ArtlyAiPressTitle-{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="artly-ai__rail artly-ai__section artly-ai__press">
    <div class="artly-ai__section-intro artly-ai__section-intro--center">
      {% if section.settings.press_heading != blank %}
        <h2 id="ArtlyAiPressTitle-{{ section.id }}">{{ section.settings.press_heading | escape }}</h2>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="artly-ai__press-grid">
        {% for block in section.blocks %}
          {% assign press_card_state_class = 'artly-ai__press-card--text-only' %}
          {% if block.settings.card_image != blank %}
            {% assign press_card_state_class = 'artly-ai__press-card--has-image' %}
          {% endif %}
          <article class="artly-ai__press-card {{ press_card_state_class }}" {{ block.shopify_attributes }}>
            {% if block.settings.card_image != blank %}
              {% assign press_image_alt = block.settings.card_image_alt_text | default: block.settings.heading %}
              <div class="artly-ai__press-media">
                {{
                  block.settings.card_image
                  | image_url: width: 960
                  | image_tag:
                    width: block.settings.card_image.width,
                    widths: '320, 480, 640, 960',
                    height: block.settings.card_image.height,
                    alt: press_image_alt,
                    loading: 'lazy',
                    class: 'artly-ai__press-image'
                }}
              </div>
            {% endif %}
            <h3>{{ block.settings.heading | escape }}</h3>
            {% if block.settings.body != blank %}
              <p>{{ block.settings.body | escape }}</p>
            {% endif %}
            {% if block.settings.link_label != blank %}
              {% if block.settings.link == blank %}
                <span class="artly-ai__text-link artly-ai__text-link--disabled" aria-disabled="true">
                  {{ block.settings.link_label | escape }}
                </span>
              {% else %}
                <a class="artly-ai__text-link" href="{{ block.settings.link }}">
                  {{ block.settings.link_label | escape }}
                </a>
              {% endif %}
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Artly AI press",
  "class": "artly-ai-press-section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "press_heading",
      "label": "Heading",
      "default": "Press"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "press_item",
      "name": "Press item",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "card_image_alt_text",
          "label": "Card image alt text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Press headline coming soon"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Add a short summary of the article or announcement here."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Read the Article"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Artly AI press"
    }
  ]
}
{% endschema %}
