<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size
    assign grid_columns = total_blocks | at_most: 4
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if total_blocks > 4 %}footer-content--has-intro{% endif %}
    "
    style="
      {% render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

<style>
  footer #shopify-section-{{ section.id }} .footer-content--has-intro .logo-block {
    --artly-footer-logo-width: clamp(118px, 34vw, 164px);
    --logo-width: var(--artly-footer-logo-width) !important;
    --logo-width-mobile: var(--artly-footer-logo-width) !important;

    width: var(--artly-footer-logo-width) !important;
    max-width: 100% !important;
    flex: 0 0 auto;
  }

  footer #shopify-section-{{ section.id }} .footer-content--has-intro .logo-block__image-wrapper,
  footer #shopify-section-{{ section.id }} .footer-content--has-intro img.logo-block__image {
    width: var(--artly-footer-logo-width) !important;
    max-width: 100% !important;
  }

  footer #shopify-section-{{ section.id }} .footer-content--has-intro img.logo-block__image {
    display: block;
    height: auto !important;
  }

  @media screen and (min-width: 990px) {
    footer #shopify-section-{{ section.id }} .footer-content--has-intro .logo-block {
      --artly-footer-logo-width: clamp(132px, 12vw, 184px);
    }
  }
</style>

{% stylesheet %}
  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
    align-items: start;
  }

  .footer-content .menu__heading__default {
    font-weight: var(--font-heading--weight);
  }

  .footer-content ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-content li {
    margin-block: 0.25rem;
    list-style: none;
  }

  .footer-content--has-intro > :first-child {
    grid-column: 1 / -1;
  }

  .footer-content--has-intro > :first-child .divider {
    display: none;
  }

footer .footer-content--has-intro > :first-child .logo-block {
  --artly-footer-logo-width: clamp(118px, 34vw, 164px);
  --logo-width: var(--artly-footer-logo-width) !important;
  --logo-width-mobile: var(--artly-footer-logo-width) !important;

  width: var(--artly-footer-logo-width) !important;
  max-width: 100% !important;
  flex: 0 0 auto;
  margin-bottom: 14px;
}

footer .footer-content--has-intro > :first-child .logo-block__image-wrapper {
  width: var(--artly-footer-logo-width) !important;
  max-width: 100% !important;
  flex: 0 0 auto;
}

footer .footer-content--has-intro > :first-child img.logo-block__image {
  display: block;
  width: var(--artly-footer-logo-width) !important;
  max-width: 100% !important;
  height: auto !important;
}

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(min(var(--grid-columns), 3), 1fr);
      grid-auto-flow: row;
    }

    .footer-content[style*='--grid-columns: 4'] {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-content--has-intro > :first-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    .footer-content--has-intro {
      grid-template-columns: minmax(300px, 32%) repeat(var(--grid-columns), minmax(112px, 1fr));
      column-gap: clamp(28px, 4vw, var(--footer-gap));
      row-gap: var(--footer-gap);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--has-intro > :first-child {
      grid-column: auto;
      max-width: 380px;
      min-width: 0;
    }

    .footer-content--has-intro > :not(:first-child) {
      min-width: 0;
    }

    .footer-content--has-intro > :first-child .group-block-content {
      gap: 10px;
      align-items: stretch;
    }

footer .footer-content--has-intro > :first-child .logo-block {
  --artly-footer-logo-width: clamp(132px, 12vw, 184px);
  --logo-width: var(--artly-footer-logo-width) !important;
  --logo-width-mobile: var(--artly-footer-logo-width) !important;

  width: var(--artly-footer-logo-width) !important;
  margin-bottom: 16px;
}

    .footer-content--has-intro > :first-child .logo-block + .text-block {
      margin-top: 8px;
    }

    .footer-content--has-intro > :first-child .text-block h2 {
      font-size: clamp(1.04rem, 1.2vw, 1.18rem);
      line-height: 1.22;
    }

    .footer-content--has-intro > :first-child .text-block p {
      font-size: 0.86rem;
      line-height: 1.5;
    }

    .footer-content--has-intro > :first-child .email-signup-block {
      width: 100%;
      min-width: 0;
      margin-top: 4px;
    }

    .footer-content--has-intro > :first-child .email-signup__input-group {
      width: 100%;
      gap: 8px;
      align-items: stretch;
    }

    .footer-content--has-intro > :first-child .email-signup__input {
      min-width: 0;
    }

    .footer-content--has-intro > :first-child .email-signup__button--text {
      flex: 0 0 auto;
      padding-inline: 18px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
