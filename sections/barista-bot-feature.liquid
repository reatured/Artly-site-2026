        {
          "value": "50svh",
          "label": "50svh"
        },
        {
          "value": "60svh",
          "label": "60svh"
        },
        {
          "value": "80svh",
          "label": "80svh"
        },
        {
          "value": "100svh",
          "label": "100svh"
        }
      ],
      "default": "60svh"
