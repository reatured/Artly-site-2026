      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Barista bot feature",
      "category": "Storytelling",
      "settings": {
        "media_type": "video",
        "media_position": "left",
        "media_width": "wide",
        "media_height": "60svh",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
