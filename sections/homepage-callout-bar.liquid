{% assign campaign_mode = section.settings.campaign_mode %}
{% assign show_signup_mode = false %}
{% assign show_cta = true %}
{% assign show_countdown = false %}
{% assign show_signup_form = false %}
{% assign countdown_enabled = false %}
{% assign should_render_section = false %}

{% if section.settings.bar_text != blank %}
  {% assign should_render_section = true %}
{% endif %}

{% if campaign_mode == 'message_with_countdown' and section.settings.enable_countdown %}
  {% assign show_countdown = true %}
{% endif %}

{% if campaign_mode == 'signup' %}
  {% assign show_signup_mode = true %}
{% endif %}

{% if campaign_mode == 'signup' and section.settings.cta_hidden_when_mode_signup %}
  {% assign show_cta = false %}
{% endif %}

{% if campaign_mode == 'signup' and section.settings.signup_enabled %}
  {% assign show_signup_form = true %}
{% endif %}

{% if show_countdown and section.settings.countdown_end_date != blank and section.settings.countdown_end_time != blank %}
  {% assign countdown_enabled = true %}
{% endif %}

{% if should_render_section %}
  <section
    class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} homepage-callout-bar"
    style="--callout-divider-width: {% if section.settings.show_divider %}1px{% else %}0px{% endif %}; {% render 'spacing-style', settings: section.settings %}"
  >
    <div class="homepage-callout-bar__content">
      <div class="homepage-callout-bar__message-wrap alignment-{{ section.settings.alignment }}">
        <div class="homepage-callout-bar__text rte">
          {{ section.settings.bar_text }}
        </div>

        {% if show_countdown and countdown_enabled %}
          <div
            class="homepage-callout-bar__countdown"
            data-homepage-callout-countdown
            data-callout-end-date="{{ section.settings.countdown_end_date | escape }}"
            data-callout-end-time="{{ section.settings.countdown_end_time | escape }}"
            data-callout-show-units="{{ section.settings.show_countdown_units }}"
          >
            <span class="homepage-callout-bar__countdown-label">{{ section.settings.countdown_label }}</span>
            <div
              class="homepage-callout-bar__countdown-values"
              role="timer"
              aria-live="polite"
              aria-atomic="true"
            >
              <span class="homepage-callout-bar__countdown-unit-wrap">
                <span class="homepage-callout-bar__countdown-value" data-callout-part="days">--</span>
                <span class="homepage-callout-bar__countdown-unit" {% unless section.settings.show_countdown_units %}hidden{% endunless %}>d</span>
              </span>
              <span class="homepage-callout-bar__countdown-unit-wrap">
                <span class="homepage-callout-bar__countdown-value" data-callout-part="hours">--</span>
                <span class="homepage-callout-bar__countdown-unit" {% unless section.settings.show_countdown_units %}hidden{% endunless %}>h</span>
              </span>
              <span class="homepage-callout-bar__countdown-unit-wrap">
                <span class="homepage-callout-bar__countdown-value" data-callout-part="minutes">--</span>
                <span class="homepage-callout-bar__countdown-unit" {% unless section.settings.show_countdown_units %}hidden{% endunless %}>m</span>
              </span>
              <span class="homepage-callout-bar__countdown-unit-wrap">
                <span class="homepage-callout-bar__countdown-value" data-callout-part="seconds">--</span>
                <span class="homepage-callout-bar__countdown-unit" {% unless section.settings.show_countdown_units %}hidden{% endunless %}>s</span>
              </span>
            </div>
            <p class="homepage-callout-bar__expired-message" data-homepage-callout-countdown-expired hidden>
              {{ section.settings.countdown_expired_message }}
            </p>
          </div>
        {% elsif show_countdown %}
          <p class="homepage-callout-bar__expired-message">
            {{ section.settings.countdown_expired_message }}
          </p>
        {% endif %}
      </div>

      <div class="homepage-callout-bar__action">
        {% if show_signup_mode %}
          {% if show_signup_form %}
            <p class="homepage-callout-bar__signup-subtext">{{ section.settings.signup_subtext }}</p>
            {% assign form_id = 'HomepageCalloutSignup-' | append: section.id %}
            {% form 'customer', id: form_id, class: 'homepage-callout-bar__form' %}
              <label class="visually-hidden" for="HomepageCalloutEmail-{{ section.id }}">
                Email address
              </label>
              <input
                id="HomepageCalloutEmail-{{ section.id }}"
                class="homepage-callout-bar__input"
                type="email"
                name="contact[email]"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="{{ section.settings.signup_placeholder }}"
                required
                value="{{ form.email }}"
                {% if form.errors and form.id == form_id %}
                  aria-invalid="true"
                  aria-describedby="HomepageCalloutEmailError-{{ section.id }}"
                {% endif %}
              >

              <button
                class="button {{ section.settings.signup_button_style }}"
                type="submit"
              >
                {{ section.settings.signup_button_text }}
              </button>

              {% if section.settings.signup_consent_text != blank %}
                <p class="homepage-callout-bar__consent" id="HomepageCalloutConsent-{{ section.id }}">
                  {{ section.settings.signup_consent_text }}
                </p>
              {% endif %}

              {% if form.errors and form.id == form_id %}
                <p class="homepage-callout-bar__form-message homepage-callout-bar__form-message--error" id="HomepageCalloutEmailError-{{ section.id }}">
                  {{ section.settings.signup_error_message }}
                </p>
              {% elsif form.posted_successfully? and form.id == form_id %}
                <p class="homepage-callout-bar__form-message homepage-callout-bar__form-message--success">
                  {{ section.settings.signup_success_message }}
                </p>
              {% endif %}
            {% endform %}
          {% elsif section.settings.signup_subtext != blank %}
            <p class="homepage-callout-bar__signup-subtext">{{ section.settings.signup_subtext }}</p>
          {% endif %}
        {% elsif show_cta and section.settings.cta_text != blank %}
          {% if section.settings.cta_link != blank %}
            <a
              href="{{ section.settings.cta_link }}"
              class="button {{ section.settings.cta_style }}"
              {% if section.settings.cta_open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              {{ section.settings.cta_text }}
            </a>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% javascript %}
  (function () {
    const nodes = Array.from(document.querySelectorAll('[data-homepage-callout-countdown]'));
    if (!nodes.length) {
      return;
    }

    const SECOND_MS = 1000;
    const MINUTE_MS = 60 * SECOND_MS;
    const HOUR_MS = 60 * MINUTE_MS;
    const DAY_MS = 24 * HOUR_MS;

    function parseEndTime(node) {
      const date = (node.dataset.calloutEndDate || '').trim();
      const time = (node.dataset.calloutEndTime || '').trim();

      if (!date || !time) {
        return null;
      }

      const parsed = new Date(`${date}T${time}`);
      const timeValue = parsed && !Number.isNaN(parsed.getTime()) ? parsed.getTime() : null;

      return timeValue;
    }

    function formatPart(value) {
      return String(Math.max(0, value)).padStart(2, '0');
    }

    function setExpired(node) {
      const values = node.querySelector('[role=\"timer\"]');
      const message = node.querySelector('[data-homepage-callout-countdown-expired]');

      if (values) {
        values.hidden = true;
      }

      if (message && message.textContent.trim() !== '') {
        message.hidden = false;
      }
    }

    function clear(node) {
      const timer = node.__calloutCountdownTimer;
      if (timer) {
        clearInterval(timer);
        node.__calloutCountdownTimer = null;
      }
    }

    function render(node, endTime) {
      const remaining = endTime - Date.now();
      const values = node.querySelector('[role=\"timer\"]');
      if (!values) {
        return;
      }

      if (!Number.isFinite(remaining) || remaining <= 0) {
        clear(node);
        setExpired(node);
        return;
      }

      const days = Math.floor(remaining / DAY_MS);
      const hours = Math.floor((remaining % DAY_MS) / HOUR_MS);
      const minutes = Math.floor((remaining % HOUR_MS) / MINUTE_MS);
      const seconds = Math.floor((remaining % MINUTE_MS) / SECOND_MS);

      values.querySelector('[data-callout-part=\"days\"]').textContent = formatPart(days);
      values.querySelector('[data-callout-part=\"hours\"]').textContent = formatPart(hours);
      values.querySelector('[data-callout-part=\"minutes\"]').textContent = formatPart(minutes);
      values.querySelector('[data-callout-part=\"seconds\"]').textContent = formatPart(seconds);
    }

    nodes.forEach((node) => {
      clear(node);

      const endTime = parseEndTime(node);
      const values = node.querySelector('[role=\"timer\"]');

      if (!endTime || !values) {
        setExpired(node);
        return;
      }

      render(node, endTime);
      node.__calloutCountdownTimer = window.setInterval(() => render(node, endTime), SECOND_MS);
    });

    window.addEventListener('pagehide', () => {
      nodes.forEach(clear);
    });
  })();
{% endjavascript %}

{% stylesheet %}
  .homepage-callout-bar {
    border-block-end: var(--callout-divider-width) solid var(--color-border);
  }

  .homepage-callout-bar__content {
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    align-items: center;
    gap: var(--gap-lg);
  }

  .alignment-left .homepage-callout-bar__text {
    text-align: left;
  }

  .alignment-center .homepage-callout-bar__text {
    text-align: center;
  }

  .alignment-left .homepage-callout-bar__countdown {
    justify-content: flex-start;
  }

  .alignment-center .homepage-callout-bar__countdown {
    justify-content: center;
  }

  .homepage-callout-bar__message-wrap {
    min-width: 0;
  }

  .homepage-callout-bar__text {
    margin: 0;
    font-size: var(--font-size-md, 1rem);
    line-height: var(--line-height-heading);
    word-wrap: anywhere;
  }

  .homepage-callout-bar__countdown {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    margin-top: var(--gap-xs);
  }

  .homepage-callout-bar__countdown-label {
    color: var(--color-foreground-muted);
    margin: 0;
    font-size: var(--font-size-sm, 0.8125rem);
  }

  .homepage-callout-bar__countdown-values {
    display: flex;
    align-items: baseline;
    gap: var(--gap-xs);
    min-width: 0;
  }

  .homepage-callout-bar__countdown-values[hidden] {
    display: none;
  }

  .homepage-callout-bar__countdown-unit-wrap {
    display: inline-flex;
    align-items: baseline;
    gap: 0.2rem;
  }

  .homepage-callout-bar__countdown-value {
    font-size: var(--font-size-lg, 1rem);
    font-variant-numeric: tabular-nums;
  }

  .homepage-callout-bar__countdown-unit {
    font-size: var(--font-size-sm, 0.8125rem);
    color: var(--color-foreground-muted);
  }

  .homepage-callout-bar__expired-message {
    margin: 0;
    font-size: var(--font-size-sm, 0.8125rem);
    color: var(--color-foreground-muted);
  }

  .homepage-callout-bar__expired-message[hidden] {
    display: none;
  }

  .homepage-callout-bar__action {
    justify-self: end;
    width: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--gap-sm);
    min-width: 0;
    margin-left: auto;
  }

  .homepage-callout-bar__signup-subtext,
  .homepage-callout-bar__consent,
  .homepage-callout-bar__form-message {
    margin: 0;
    font-size: var(--font-size-sm, 0.8125rem);
    color: var(--color-foreground-muted);
    width: 100%;
  }

  .homepage-callout-bar__signup-subtext {
    color: var(--color-foreground);
    margin-bottom: 0.35rem;
  }

  .homepage-callout-bar__form {
    width: 100%;
    max-width: 100%;
    display: grid;
    gap: 0.5rem;
  }

  .homepage-callout-bar__input {
    width: 100%;
    padding: var(--padding-lg) var(--padding-md);
    min-height: 44px;
    border-radius: var(--style-border-radius-inputs);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    background: var(--color-input-background);
    color: var(--color-input-text);
  }

  .homepage-callout-bar__input,
  .homepage-callout-bar__form .button {
    width: 100%;
  }

  .homepage-callout-bar__consent {
    margin-top: 0.2rem;
    margin-bottom: 0;
    color: var(--color-foreground-muted);
  }

  .homepage-callout-bar__form-message {
    margin-top: 0.2rem;
  }

  .homepage-callout-bar__form-message--error {
    color: var(--color-error-text);
  }

  .homepage-callout-bar__form-message--success {
    color: var(--color-success-text);
  }

  .homepage-callout-bar__action .button {
    min-height: 44px;
    width: auto;
  }

  @media screen and (max-width: 749px) {
    .homepage-callout-bar__content {
      grid-template-columns: 1fr;
    }

    .homepage-callout-bar__action,
    .homepage-callout-bar__action .button,
    .homepage-callout-bar__form .button {
      width: 100%;
      justify-content: stretch;
      justify-self: stretch;
    }

    .homepage-callout-bar__countdown {
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homepage Callout Bar",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "campaign_mode",
      "label": "Campaign mode",
      "options": [
        {
          "value": "message",
          "label": "Message"
        },
        {
          "value": "message_with_countdown",
          "label": "Message + Countdown"
        },
        {
          "value": "signup",
          "label": "Signup"
        }
      ],
      "default": "message"
    },
    {
      "type": "inline_richtext",
      "id": "bar_text",
      "label": "Bar text",
      "default": "Built for real deployments, not robotics demos."
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Message alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left padding",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right padding",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Message + CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "CTA style",
      "options": [
        {
          "value": "button",
          "label": "Primary button"
        },
        {
          "value": "button-secondary",
          "label": "Secondary button"
        }
      ],
      "default": "button"
    },
    {
      "type": "checkbox",
      "id": "cta_open_in_new_tab",
      "label": "Open CTA link in new tab",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "cta_hidden_when_mode_signup",
      "label": "Hide CTA in signup mode",
      "default": true
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "label": "Enable countdown",
      "default": true,
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" }}"
    },
    {
      "type": "text",
      "id": "countdown_label",
      "label": "Countdown label",
      "default": "Ends in",
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" and section.settings.enable_countdown }}"
    },
    {
      "type": "text",
      "id": "countdown_end_date",
      "label": "Countdown end date (YYYY-MM-DD)",
      "default": "2026-07-15",
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" and section.settings.enable_countdown }}"
    },
    {
      "type": "select",
      "id": "countdown_end_time",
      "label": "Countdown end time",
      "options": [
        { "value": "00:00", "label": "00:00" },
        { "value": "01:00", "label": "01:00" },
        { "value": "02:00", "label": "02:00" },
        { "value": "03:00", "label": "03:00" },
        { "value": "04:00", "label": "04:00" },
        { "value": "05:00", "label": "05:00" },
        { "value": "06:00", "label": "06:00" },
        { "value": "07:00", "label": "07:00" },
        { "value": "08:00", "label": "08:00" },
        { "value": "09:00", "label": "09:00" },
        { "value": "10:00", "label": "10:00" },
        { "value": "11:00", "label": "11:00" },
        { "value": "12:00", "label": "12:00" },
        { "value": "13:00", "label": "13:00" },
        { "value": "14:00", "label": "14:00" },
        { "value": "15:00", "label": "15:00" },
        { "value": "16:00", "label": "16:00" },
        { "value": "17:00", "label": "17:00" },
        { "value": "18:00", "label": "18:00" },
        { "value": "19:00", "label": "19:00" },
        { "value": "20:00", "label": "20:00" },
        { "value": "21:00", "label": "21:00" },
        { "value": "22:00", "label": "22:00" },
        { "value": "23:00", "label": "23:00" }
      ],
      "default": "12:00",
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" and section.settings.enable_countdown }}"
    },
    {
      "type": "paragraph",
      "content": "Timezone note: end time uses the customer browser local timezone."
    },
    {
      "type": "checkbox",
      "id": "show_countdown_units",
      "label": "Show unit labels",
      "default": true,
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" and section.settings.enable_countdown }}"
    },
    {
      "type": "text",
      "id": "countdown_expired_message",
      "label": "Expired message",
      "default": "This campaign window has ended.",
      "visible_if": "{{ section.settings.campaign_mode == \"message_with_countdown\" and section.settings.enable_countdown }}"
    },
    {
      "type": "header",
      "content": "Signup mode"
    },
    {
      "type": "checkbox",
      "id": "signup_enabled",
      "label": "Enable signup form",
      "default": true,
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" }}"
    },
    {
      "type": "text",
      "id": "signup_subtext",
      "label": "Signup supporting text",
      "default": "Get deployment updates and launch announcements from Artly.",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" }}"
    },
    {
      "type": "text",
      "id": "signup_placeholder",
      "label": "Signup email placeholder",
      "default": "name@company.com",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" and section.settings.signup_enabled }}"
    },
    {
      "type": "text",
      "id": "signup_button_text",
      "label": "Signup button text",
      "default": "Get Updates",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" and section.settings.signup_enabled }}"
    },
    {
      "type": "select",
      "id": "signup_button_style",
      "label": "Signup button style",
      "options": [
        {
          "value": "button",
          "label": "Primary button"
        },
        {
          "value": "button-secondary",
          "label": "Secondary button"
        }
      ],
      "default": "button",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" and section.settings.signup_enabled }}"
    },
    {
      "type": "text",
      "id": "signup_success_message",
      "label": "Signup success message",
      "default": "You're on the list for campaign updates.",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" }}"
    },
    {
      "type": "text",
      "id": "signup_error_message",
      "label": "Signup error message",
      "default": "Please enter a valid email to join.",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" }}"
    },
    {
      "type": "text",
      "id": "signup_consent_text",
      "label": "Signup consent text",
      "default": "By continuing, you agree to receive Artly communications. You can unsubscribe anytime.",
      "visible_if": "{{ section.settings.campaign_mode == \"signup\" and section.settings.signup_enabled }}"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Homepage Callout Bar"
    }
  ]
}
{% endschema %}
