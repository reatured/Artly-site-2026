<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style artly-system artly-ai-l1 artly-ai-l1-hero"
  aria-labelledby="ArtlyAiHeroTitle-{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="artly-ai__hero">
    <div class="artly-ai__rail artly-ai__hero-inner">
      {% if section.settings.hero_heading != blank %}
        <h1 class="artly-ai__hero-heading" id="ArtlyAiHeroTitle-{{ section.id }}">{{ section.settings.hero_heading | escape }}</h1>
      {% endif %}

      {% if section.settings.hero_body != blank %}
        <div class="artly-ai__hero-body rte">{{ section.settings.hero_body }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="artly-ai__stat-grid" aria-label="{{ section.settings.stats_label | escape }}">
          {% for block in section.blocks %}
            <article class="artly-ai__stat" {{ block.shopify_attributes }}>
              <span class="artly-ai__stat-icon-wrap" aria-hidden="true">
                {% render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.icon_image,
                  width: 22,
                  class_name: 'artly-ai__stat-icon'
                %}
              </span>
              <span class="artly-ai__stat-content">
                <strong>{{ block.settings.value | escape }}</strong>
                <span>{{ block.settings.label | escape }}</span>
              </span>
            </article>
          {% endfor %}
        </div>
      {% endif %}

      <div class="artly-ai__hero-cta">
        <div class="artly-ai__hero-cta-copy">
          {% if section.settings.hero_cta_heading != blank %}
            <p class="artly-ai__cta-heading">{{ section.settings.hero_cta_heading | escape }}</p>
          {% endif %}
          {% if section.settings.hero_cta_body != blank %}
            <div class="artly-ai__cta-body rte">{{ section.settings.hero_cta_body }}</div>
          {% endif %}
        </div>
        <div class="artly-ai__actions">
          {% if section.settings.contact_label != blank %}
            <button
              class="artly-button artly-button--secondary"
              type="button"
              data-artly-ai-contact-trigger="true"
              aria-expanded="false"
              aria-controls="artly-ai-contact-modal"
            >
              {{ section.settings.contact_label | escape }}
            </button>
          {% endif %}
          {% if section.settings.demo_label != blank %}
            <button
              class="artly-button artly-button--primary"
              type="button"
              data-artly-ai-contact-trigger="true"
              aria-expanded="false"
              aria-controls="artly-ai-contact-modal"
            >
              {{ section.settings.demo_label | escape }}
            </button>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% assign artly_ai_contact_form_id = 'ArtlyAiContactForm-' | append: section.id %}
{% assign artly_ai_contact_return_to = request.path | default: routes.root_url | append: '#artly-ai-contact-modal' %}

<div
  id="artly-ai-contact-modal"
  class="artly-ai__demo-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="ArtlyAiContactModalTitle"
  aria-describedby="ArtlyAiContactModalDescription"
  hidden
>
  <button
    type="button"
    class="artly-ai__demo-backdrop"
    aria-label="Close contact popup"
    data-artly-ai-contact-close
  ></button>
  <div class="artly-ai__demo-panel-wrap">
    <div class="artly-ai__demo-panel">
      <div class="artly-ai__demo-header">
        <div>
          <h2 id="ArtlyAiContactModalTitle" class="artly-ai__demo-title">Contact the Artly Team</h2>
          <p id="ArtlyAiContactModalDescription" class="artly-ai__demo-description">
            Tell us about your operation and we'll reply with a recommended deployment approach.
          </p>
        </div>
        <button
          type="button"
          class="artly-ai__demo-close"
          aria-label="Close contact popup"
          data-artly-ai-contact-close
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>

      {%- form 'contact', id: artly_ai_contact_form_id, return_to: artly_ai_contact_return_to -%}
        {% if form.errors %}
          <div class="artly-ai__demo-message artly-ai__demo-message--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% elsif form.posted_successfully? %}
          <div class="artly-ai__demo-message artly-ai__demo-message--success" role="status">
            Thanks for reaching out. One of our specialists will get in touch shortly.
          </div>
        {% endif %}

        <input type="hidden" name="contact[tags]" value="Artly AI Contact Request">

        <div class="artly-ai__demo-field">
          <label for="ArtlyAiContactName-{{ section.id }}">Name</label>
          <input
            id="ArtlyAiContactName-{{ section.id }}"
            class="artly-ai__demo-input"
            type="text"
            name="contact[name]"
            autocomplete="name"
            required
          >
        </div>

        <div class="artly-ai__demo-field">
          <label for="ArtlyAiContactEmail-{{ section.id }}">Email</label>
          <input
            id="ArtlyAiContactEmail-{{ section.id }}"
            class="artly-ai__demo-input"
            type="email"
            name="contact[email]"
            autocomplete="email"
            required
          >
        </div>

        <div class="artly-ai__demo-field">
          <label for="ArtlyAiContactCompany-{{ section.id }}">Company</label>
          <input
            id="ArtlyAiContactCompany-{{ section.id }}"
            class="artly-ai__demo-input"
            type="text"
            name="contact[company]"
            autocomplete="organization"
          >
        </div>

        <div class="artly-ai__demo-field">
          <label for="ArtlyAiContactMessage-{{ section.id }}">Project goals</label>
          <textarea
            id="ArtlyAiContactMessage-{{ section.id }}"
            class="artly-ai__demo-textarea"
            name="contact[body]"
            rows="5"
            required
          ></textarea>
        </div>

        <button class="artly-button artly-button--primary artly-ai__demo-submit" type="submit">
          Send request
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

<script>
(function() {
  if (window.__artlyAiContactModalInitialized) return;
  window.__artlyAiContactModalInitialized = true;

  const modal = document.getElementById('artly-ai-contact-modal');
  if (!modal) return;

  const triggerSelector = '[data-artly-ai-contact-trigger]';
  const closeTargets = Array.from(modal.querySelectorAll('[data-artly-ai-contact-close]'));
  const focusableSelector = [
    'a[href]',
    'button:not([disabled])',
    'input:not([disabled])',
    'select:not([disabled])',
    'textarea:not([disabled])',
    '[tabindex]:not([tabindex=\"-1\"])'
  ].join(',');
  let lastTrigger = null;

  function getTriggers() {
    return Array.from(document.querySelectorAll(triggerSelector));
  }

  function getFocusableElements() {
    return Array.from(modal.querySelectorAll(focusableSelector))
      .filter((element) => element.offsetParent !== null);
  }

  function setOpenState(open, trigger) {
    if (!modal) return;
    const formMessage = modal.querySelector('.artly-ai__demo-message');
    if (open) {
      lastTrigger = trigger;
      modal.hidden = false;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('artly-ai-modal-open');
      getTriggers().forEach((button) => button.setAttribute('aria-expanded', button === trigger ? 'true' : 'false'));
      const focusables = getFocusableElements();
      const initialFocus = focusables[0] || modal;
      window.requestAnimationFrame(() => {
        initialFocus.focus({ preventScroll: true });
      });
      if (formMessage) {
        formMessage.textContent = '';
        formMessage.hidden = true;
      }
    } else {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('artly-ai-modal-open');
      getTriggers().forEach((button) => button.setAttribute('aria-expanded', 'false'));
      if (lastTrigger && lastTrigger.focus) {
        lastTrigger.focus({ preventScroll: true });
      }
      modal.hidden = true;
    }
  }

  window.__artlyAiContactModalController = window.__artlyAiContactModalController || {};
  window.__artlyAiContactModalController.open = function (trigger) {
    setOpenState(true, trigger);
  };
  window.__artlyAiContactModalController.close = function () {
    setOpenState(false);
  };
  window.__artlyAiContactModalController.isOpen = function () {
    return modal.classList.contains('is-open');
  };

  function handleBackdropClose(event) {
    if (event.target.closest('.artly-ai__demo-panel')) return;
    setOpenState(false);
  }

  function handleKeydown(event) {
    if (!modal.classList.contains('is-open')) return;
    if (event.key === 'Escape') {
      setOpenState(false);
      return;
    }
    if (event.key !== 'Tab') return;

    const focusable = getFocusableElements();
    if (!focusable.length) {
      event.preventDefault();
      modal.focus();
      return;
    }

    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  }

  document.addEventListener('click', function (event) {
    const trigger = event.target.closest(triggerSelector);
    if (!trigger) return;

    event.preventDefault();
    if (modal.classList.contains('is-open')) {
      setOpenState(false);
      return;
    }
    setOpenState(true, trigger);
  });

  closeTargets.forEach((button) => {
    button.addEventListener('click', () => setOpenState(false));
  });

  modal.addEventListener('click', handleBackdropClose);
  document.addEventListener('keydown', handleKeydown);
})();
</script>

{% schema %}
{
  "name": "Artly AI hero",
  "class": "artly-ai-hero-section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "The Core Training Layer for Physical AI"
    },
    {
      "type": "richtext",
      "id": "hero_body",
      "label": "Subhead",
      "default": "<p>Artly AI turns expert human knowledge into specialized, production-ready robots. Built on imitation learning and real-world data, our robot training services are the fastest path from concept to deployment.</p>"
    },
    {
      "type": "text",
      "id": "stats_label",
      "label": "Stats accessibility label",
      "default": "Artly AI proof points"
    },
    {
      "type": "text",
      "id": "hero_cta_heading",
      "label": "CTA heading",
      "default": "Get deployment-ready robots fast, no coding required."
    },
    {
      "type": "richtext",
      "id": "hero_cta_body",
      "label": "CTA body",
      "default": "<p>Tell us about your operation, and we'll design a training solution built around it.</p>"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    },
    {
      "type": "text",
      "id": "demo_label",
      "label": "Demo button label",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "demo_link",
      "label": "Demo button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Hero stat",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "stopwatch", "label": "Stopwatch" },
            { "value": "lightning_bolt", "label": "Lightning" },
            { "value": "world", "label": "World" },
            { "value": "check_box", "label": "Checklist" },
            { "value": "flywheel", "label": "Flywheel" }
          ],
          "default": "stopwatch"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "30-Minute"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Training Time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Artly AI hero"
    }
  ]
}
{% endschema %}
