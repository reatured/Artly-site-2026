<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{% assign hero_demo_form_id = 'ArtlyAiHeroDemoForm-' | append: section.id %}
{% assign hero_demo_return_to = request.path | default: routes.root_url | append: '#artly-ai-hero-demo-anchor-' | append: section.id %}

<section
  id="artly-ai-hero-demo-anchor-{{ section.id }}"
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style artly-system artly-ai-l1 artly-ai-l1-hero"
  aria-labelledby="ArtlyAiHeroTitle-{{ section.id }}"
  data-artly-ai-demo-section
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="artly-ai__hero">
    <div class="artly-ai__rail artly-ai__hero-inner">
      {% if section.settings.hero_heading != blank %}
        <h1 class="artly-ai__hero-heading" id="ArtlyAiHeroTitle-{{ section.id }}">{{ section.settings.hero_heading | escape }}</h1>
      {% endif %}

      {% if section.settings.hero_body != blank %}
        <div class="artly-ai__hero-body rte">{{ section.settings.hero_body }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="artly-ai__stat-grid" aria-label="{{ section.settings.stats_label | escape }}">
          {% for block in section.blocks %}
            <article class="artly-ai__stat" {{ block.shopify_attributes }}>
              <span class="artly-ai__stat-icon-wrap" aria-hidden="true">
                {% render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.icon_image,
                  width: 22,
                  class_name: 'artly-ai__stat-icon'
                %}
              </span>
              <span class="artly-ai__stat-content">
                <strong>{{ block.settings.value | escape }}</strong>
                <span>{{ block.settings.label | escape }}</span>
              </span>
            </article>
          {% endfor %}
        </div>
      {% endif %}

      <div class="artly-ai__hero-cta">
        <div class="artly-ai__hero-cta-copy">
          {% if section.settings.hero_cta_heading != blank %}
            <p class="artly-ai__cta-heading">{{ section.settings.hero_cta_heading | escape }}</p>
          {% endif %}
          {% if section.settings.hero_cta_body != blank %}
            <div class="artly-ai__cta-body rte">{{ section.settings.hero_cta_body }}</div>
          {% endif %}
        </div>
        <div class="artly-ai__actions">
          {% if section.settings.contact_label != blank %}
            <button
              id="ArtlyAiHeroContactTrigger-{{ section.id }}"
              type="button"
              class="artly-button artly-button--secondary"
              data-artly-ai-demo-trigger
              aria-expanded="false"
              aria-controls="ArtlyAiHeroDemoModal-{{ section.id }}"
            >
              {{ section.settings.contact_label | escape }}
            </button>
          {% endif %}
          {% if section.settings.demo_label != blank %}
            <button
              id="ArtlyAiHeroDemoTrigger-{{ section.id }}"
              type="button"
              class="artly-button artly-button--primary"
              data-artly-ai-demo-trigger
              aria-expanded="false"
              aria-controls="ArtlyAiHeroDemoModal-{{ section.id }}"
              data-artly-ai-demo-modal-target="ArtlyAiHeroDemoModal-{{ section.id }}"
            >
              {{ section.settings.demo_label | escape }}
            </button>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<div
  id="ArtlyAiHeroDemoModal-{{ section.id }}"
  class="artly-ai__demo-modal"
  data-artly-ai-demo-modal
  hidden
  aria-hidden="true"
>
  <button
    type="button"
    class="artly-ai__demo-backdrop"
    data-artly-ai-demo-backdrop
    aria-label="Close contact modal"
    tabindex="-1"
  ></button>
  <div class="artly-ai__demo-panel-wrap">
    <div
      class="artly-ai__demo-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ArtlyAiHeroDemoHeading-{{ section.id }}"
      aria-describedby="ArtlyAiHeroDemoDescription-{{ section.id }}"
      tabindex="-1"
      data-artly-ai-demo-dialog
    >
      <div class="artly-ai__demo-header">
        <h2 id="ArtlyAiHeroDemoHeading-{{ section.id }}" class="artly-ai__demo-title">Book a Demo</h2>
        <button
          type="button"
          class="artly-ai__demo-close"
          data-artly-ai-demo-close
          aria-label="Close contact form"
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>
      </div>
      <p id="ArtlyAiHeroDemoDescription-{{ section.id }}" class="artly-ai__demo-description">
        Fill out your information and we will follow up to schedule a demo.
      </p>

      {%- form 'customer', id: hero_demo_form_id, class: 'artly-ai__demo-form', return_to: hero_demo_return_to -%}
        <input name="contact[tags]" type="hidden" value="artly-ai,hero-demo">

        {%- if form.errors and form.id == hero_demo_form_id -%}
          <div
            class="artly-ai__demo-message artly-ai__demo-message--error"
            id="ArtlyAiHeroDemoError-{{ section.id }}"
            tabindex="-1"
            data-artly-ai-demo-message
          >
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? and form.id == hero_demo_form_id -%}
          <p
            class="artly-ai__demo-message artly-ai__demo-message--success"
            id="ArtlyAiHeroDemoSuccess-{{ section.id }}"
            tabindex="-1"
            data-artly-ai-demo-message
          >
            Thanks — your request was submitted.
          </p>
        {%- endif -%}

        <div class="artly-ai__demo-field">
          <label for="ArtlyAiHeroDemoName-{{ section.id }}">Name</label>
          <input
            id="ArtlyAiHeroDemoName-{{ section.id }}"
            class="artly-ai__demo-input"
            type="text"
            name="contact[first_name]"
            autocomplete="name"
            value="{% if customer %}{{ customer.first_name }}{% endif %}"
            required
          >
        </div>
        <div class="artly-ai__demo-field">
          <label for="ArtlyAiHeroDemoEmail-{{ section.id }}">Work email</label>
          <input
            id="ArtlyAiHeroDemoEmail-{{ section.id }}"
            class="artly-ai__demo-input"
            type="email"
            name="contact[email]"
            autocomplete="email"
            spellcheck="false"
            autocapitalize="off"
            value="{% if customer %}{{ customer.email }}{% endif %}"
            required
          >
        </div>
        <div class="artly-ai__demo-field">
          <label for="ArtlyAiHeroDemoBody-{{ section.id }}">Tell us about your operation</label>
          <textarea
            id="ArtlyAiHeroDemoBody-{{ section.id }}"
            class="artly-ai__demo-textarea"
            name="contact[body]"
            rows="4"
            required
          ></textarea>
        </div>
        <button class="artly-button artly-button--primary artly-ai__demo-submit" type="submit">Request a Demo</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% javascript %}
  (function () {
    const modal = document.getElementById('ArtlyAiHeroDemoModal-{{ section.id }}');
    const contactTrigger = document.getElementById('ArtlyAiHeroContactTrigger-{{ section.id }}');
    const demoTrigger = document.getElementById('ArtlyAiHeroDemoTrigger-{{ section.id }}');
    const triggers = [contactTrigger, demoTrigger].filter((element) => element instanceof HTMLElement);

    if (!modal || triggers.length === 0) {
      return;
    }

    const backdrop = modal.querySelector('[data-artly-ai-demo-backdrop]');
    const closeButton = modal.querySelector('[data-artly-ai-demo-close]');
    const dialog = modal.querySelector('[data-artly-ai-demo-dialog]');
    const messageNode = modal.querySelector('[data-artly-ai-demo-message]');
    let activeTrigger = null;
    let restoreFocusTarget = null;
    let previousOverflow = '';

    function getFocusableElements() {
      if (!modal) {
        return [];
      }

      const selector = [
        'a[href]',
        'button:not([disabled]):not([tabindex="-1"])',
        'input:not([disabled])',
        'select:not([disabled])',
        'textarea:not([disabled])',
        'details:not([disabled])',
        '[tabindex]:not([disabled]):not([tabindex="-1"])'
      ].join(',');

      return Array.from(modal.querySelectorAll(selector)).filter((element) => {
        return element.offsetParent !== null;
      });
    }

    function openModal(trigger) {
      restoreFocusTarget = document.activeElement;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      activeTrigger = trigger instanceof HTMLElement ? trigger : null;

      triggers.forEach((button) => {
        if (button instanceof HTMLElement) {
          button.setAttribute('aria-expanded', 'true');
        }
      });
      previousOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';

      if (!modal.classList.contains('is-open')) {
        modal.classList.add('is-open');
      }

      requestAnimationFrame(() => {
        const first = modal.querySelector('input,textarea,button,select');
        if (first instanceof HTMLElement) {
          first.focus({ preventScroll: true });
        }

        if (messageNode instanceof HTMLElement) {
          messageNode.focus();
        }
      });

      document.addEventListener('keydown', handleKeyDown);
    }

    function closeModal() {
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('is-open');
      triggers.forEach((button) => {
        if (button instanceof HTMLElement) {
          button.setAttribute('aria-expanded', 'false');
        }
      });
      document.body.style.overflow = previousOverflow;

      document.removeEventListener('keydown', handleKeyDown);

      if (activeTrigger instanceof HTMLElement) {
        activeTrigger.focus({ preventScroll: true });
      } else if (restoreFocusTarget instanceof HTMLElement) {
        restoreFocusTarget.focus({ preventScroll: true });
      }
    }

    function trapTab(event) {
      if (event.key !== 'Tab') {
        return;
      }

      const focusable = getFocusableElements();
      if (!focusable.length) {
        event.preventDefault();
        return;
      }

      const firstItem = focusable[0];
      const lastItem = focusable[focusable.length - 1];
      const activeElement = document.activeElement;

      if (event.shiftKey) {
        if (activeElement === firstItem || activeElement === null) {
          lastItem.focus({ preventScroll: true });
          event.preventDefault();
        }
      } else if (activeElement === lastItem) {
        firstItem.focus({ preventScroll: true });
        event.preventDefault();
      }
    }

    function handleKeyDown(event) {
      if (event.key === 'Escape') {
        closeModal();
        return;
      }

      if (event.key === 'Tab') {
        trapTab(event);
      }
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openModal(trigger);
      });
    });

    if (backdrop) {
      backdrop.addEventListener('click', closeModal);
    }

    if (closeButton) {
      closeButton.addEventListener('click', closeModal);
    }

    if (messageNode && messageNode.textContent.trim()) {
      openModal();
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Artly AI hero",
  "class": "artly-ai-hero-section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "The Core Training Layer for Physical AI"
    },
    {
      "type": "richtext",
      "id": "hero_body",
      "label": "Subhead",
      "default": "<p>Artly AI turns expert human knowledge into specialized, production-ready robots. Built on imitation learning and real-world data, our robot training services are the fastest path from concept to deployment.</p>"
    },
    {
      "type": "text",
      "id": "stats_label",
      "label": "Stats accessibility label",
      "default": "Artly AI proof points"
    },
    {
      "type": "text",
      "id": "hero_cta_heading",
      "label": "CTA heading",
      "default": "Get deployment-ready robots fast, no coding required."
    },
    {
      "type": "richtext",
      "id": "hero_cta_body",
      "label": "CTA body",
      "default": "<p>Tell us about your operation, and we'll design a training solution built around it.</p>"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    },
    {
      "type": "text",
      "id": "demo_label",
      "label": "Demo button label",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "demo_link",
      "label": "Demo button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Hero stat",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "stopwatch", "label": "Stopwatch" },
            { "value": "lightning_bolt", "label": "Lightning" },
            { "value": "world", "label": "World" },
            { "value": "check_box", "label": "Checklist" },
            { "value": "flywheel", "label": "Flywheel" }
          ],
          "default": "stopwatch"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "30-Minute"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Training Time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Artly AI hero"
    }
  ]
}
{% endschema %}
