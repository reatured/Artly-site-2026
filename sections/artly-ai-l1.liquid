{% liquid
  assign demo_media_alt = section.settings.demo_media_alt_text | default: 'Artly AI robot training demonstration'
  assign how_media_alt = section.settings.how_media_alt_text | default: 'Robot deployment training plan placeholder'
  assign case_media_alt = section.settings.case_media_alt_text | default: 'Artly AI case study placeholder'
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style artly-system artly-ai-l1"
  aria-labelledby="ArtlyAiHeroTitle-{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="artly-ai__hero">
    <div class="artly-ai__rail artly-ai__hero-inner">
      {% if section.settings.hero_heading != blank %}
        <h1 class="artly-ai__hero-heading" id="ArtlyAiHeroTitle-{{ section.id }}">{{ section.settings.hero_heading | escape }}</h1>
      {% endif %}

      {% if section.settings.hero_body != blank %}
        <div class="artly-ai__hero-body rte">{{ section.settings.hero_body }}</div>
      {% endif %}

      <div class="artly-ai__stat-grid" aria-label="Artly AI proof points">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <article class="artly-ai__stat" {{ block.shopify_attributes }}>
              <span class="artly-ai__stat-icon-wrap" aria-hidden="true">
                {% render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.icon_image,
                  width: 22,
                  class_name: 'artly-ai__stat-icon'
                %}
              </span>
              <span class="artly-ai__stat-content">
                <strong>{{ block.settings.value | escape }}</strong>
                <span>{{ block.settings.label | escape }}</span>
              </span>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="artly-ai__hero-cta">
        <div class="artly-ai__hero-cta-copy">
          {% if section.settings.hero_cta_heading != blank %}
            <p class="artly-ai__cta-heading">{{ section.settings.hero_cta_heading | escape }}</p>
          {% endif %}
          {% if section.settings.hero_cta_body != blank %}
            <div class="artly-ai__cta-body rte">{{ section.settings.hero_cta_body }}</div>
          {% endif %}
        </div>
        <div class="artly-ai__actions">
          {% if section.settings.contact_label != blank %}
            <a
              class="artly-button artly-button--secondary"
              {% if section.settings.contact_link == blank %}
                role="link"
                aria-disabled="true"
              {% else %}
                href="{{ section.settings.contact_link }}"
              {% endif %}
            >
              {{ section.settings.contact_label | escape }}
            </a>
          {% endif %}
          {% if section.settings.demo_label != blank %}
            <a
              class="artly-button artly-button--primary"
              {% if section.settings.demo_link == blank %}
                role="link"
                aria-disabled="true"
              {% else %}
                href="{{ section.settings.demo_link }}"
              {% endif %}
            >
              {{ section.settings.demo_label | escape }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="artly-ai__band artly-ai__band--demo">
    <div class="artly-ai__rail artly-ai__demo">
      <div class="artly-ai__section-intro artly-ai__section-intro--center">
        {% if section.settings.demo_heading != blank %}
          <h2>{{ section.settings.demo_heading | escape }}</h2>
        {% endif %}
        {% if section.settings.demo_body != blank %}
          <div class="rte">{{ section.settings.demo_body }}</div>
        {% endif %}
      </div>

      <div class="artly-ai__video-shell" role="img" aria-label="{{ demo_media_alt | escape }}">
        {% if section.settings.demo_video_url != blank %}
          {% render 'video',
            video_from_url: true,
            video: section.settings.demo_video_url.id,
            video_type: section.settings.demo_video_url.type,
            disable_controls: section.settings.demo_video_url.type == 'youtube',
            video_class: 'artly-ai__external-video',
            video_autoplay: false,
            video_loop: false,
            video_alt: demo_media_alt,
            video_preview_image: section.settings.demo_image
          %}
        {% elsif section.settings.demo_image != blank %}
          {{
            section.settings.demo_image
            | image_url: width: 1800
            | image_tag:
              width: section.settings.demo_image.width,
              widths: '416, 600, 768, 1024, 1440, 1800',
              height: section.settings.demo_image.height,
              alt: demo_media_alt,
              loading: 'lazy',
              class: 'artly-ai__media-image'
          }}
        {% else %}
          <svg class="artly-ai__media-placeholder" viewBox="0 0 960 540" role="img" aria-labelledby="ArtlyAiDemoPlaceholderTitle-{{ section.id }}">
            <title id="ArtlyAiDemoPlaceholderTitle-{{ section.id }}">Artly AI training demo placeholder</title>
            <rect width="960" height="540" rx="8" fill="#e4eaee"/>
            <path d="M0 410c120-116 246-160 378-132v132H0Z" fill="#f4f7f9"/>
            <path d="M960 0c-92 122-220 183-384 183H314v-72h262c120 0 207-37 262-111h122Z" fill="#f5f8fa"/>
            <rect x="362" y="168" width="236" height="160" rx="8" fill="#ffffff" stroke="#ccd6dc" stroke-width="8"/>
            <circle cx="480" cy="270" r="36" fill="#f7fafb" stroke="#b8c5cd" stroke-width="8"/>
            <path d="M468 248v44l36-22-36-22Z" fill="#a5b4bd"/>
            <circle cx="260" cy="170" r="58" fill="#dbe4e9"/>
            <circle cx="632" cy="362" r="40" fill="#dbe4e9"/>
          </svg>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__advantage">
    <div class="artly-ai__section-intro artly-ai__section-intro--center">
      {% if section.settings.advantage_heading != blank %}
        <h2>{{ section.settings.advantage_heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="artly-ai__advantage-grid">
      {% for block in section.blocks %}
        {% if block.type == 'advantage' %}
          <article class="artly-ai__advantage-card" {{ block.shopify_attributes }}>
            <div class="artly-ai__advantage-icon" aria-hidden="true">
              {% render 'icon-or-image',
                icon: block.settings.icon,
                image_upload: block.settings.icon_image,
                width: 36,
                class_name: 'artly-ai__advantage-icon-svg'
              %}
            </div>
            <div>
              <h3>{{ block.settings.heading | escape }}</h3>
              {% if block.settings.body != blank %}
                <div class="rte">{{ block.settings.body }}</div>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__how">
    <div class="artly-ai__how-content">
      <div class="artly-ai__section-intro">
        {% if section.settings.how_heading != blank %}
          <h2>{{ section.settings.how_heading | escape }}</h2>
        {% endif %}
      </div>

      <div class="artly-ai__steps-grid">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            <article class="artly-ai__step" {{ block.shopify_attributes }}>
              <p class="artly-ai__step-number">{{ block.settings.number | escape }}</p>
              <h3>{{ block.settings.heading | escape }}</h3>
              {% if block.settings.body != blank %}
                <div class="rte">{{ block.settings.body }}</div>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="artly-ai__how-cta">
        {% if section.settings.how_cta_heading != blank %}
          <h3>{{ section.settings.how_cta_heading | escape }}</h3>
        {% endif %}
        {% if section.settings.how_cta_body != blank %}
          <div class="rte">{{ section.settings.how_cta_body }}</div>
        {% endif %}
        {% if section.settings.how_cta_label != blank %}
          <a
            class="artly-button artly-button--primary"
            {% if section.settings.how_cta_link == blank %}
              role="link"
              aria-disabled="true"
            {% else %}
              href="{{ section.settings.how_cta_link }}"
            {% endif %}
          >
            {{ section.settings.how_cta_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="artly-ai__image-panel" role="img" aria-label="{{ how_media_alt | escape }}">
      {% if section.settings.how_image != blank %}
        {{
          section.settings.how_image
          | image_url: width: 1400
          | image_tag:
            width: section.settings.how_image.width,
            widths: '416, 600, 768, 1024, 1400',
            height: section.settings.how_image.height,
            alt: how_media_alt,
            loading: 'lazy',
            class: 'artly-ai__media-image'
        }}
      {% else %}
        <svg class="artly-ai__image-placeholder" viewBox="0 0 560 560" role="img" aria-labelledby="ArtlyAiHowPlaceholderTitle-{{ section.id }}">
          <title id="ArtlyAiHowPlaceholderTitle-{{ section.id }}">Artly AI deployment image placeholder</title>
          <rect width="560" height="560" rx="8" fill="#dce3e8"/>
          <rect x="164" y="164" width="232" height="232" fill="#f8fafb"/>
          <path d="M164 164l232 232M396 164 164 396" stroke="#dce3e8" stroke-width="18"/>
        </svg>
      {% endif %}
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__case">
    <div class="artly-ai__image-panel" role="img" aria-label="{{ case_media_alt | escape }}">
      {% if section.settings.case_image != blank %}
        {{
          section.settings.case_image
          | image_url: width: 1400
          | image_tag:
            width: section.settings.case_image.width,
            widths: '416, 600, 768, 1024, 1400',
            height: section.settings.case_image.height,
            alt: case_media_alt,
            loading: 'lazy',
            class: 'artly-ai__media-image'
        }}
      {% else %}
        <svg class="artly-ai__image-placeholder" viewBox="0 0 560 448" role="img" aria-labelledby="ArtlyAiCasePlaceholderTitle-{{ section.id }}">
          <title id="ArtlyAiCasePlaceholderTitle-{{ section.id }}">Artly AI case study image placeholder</title>
          <rect width="560" height="448" rx="8" fill="#dce3e8"/>
          <rect x="174" y="128" width="212" height="192" fill="#f8fafb"/>
          <path d="M174 128l212 192M386 128 174 320" stroke="#dce3e8" stroke-width="16"/>
        </svg>
      {% endif %}
    </div>

    <div class="artly-ai__case-copy">
      {% if section.settings.case_eyebrow != blank %}
        <p class="artly-ai__eyebrow">{{ section.settings.case_eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.case_heading != blank %}
        <h2>{{ section.settings.case_heading | escape }}</h2>
      {% endif %}
      {% if section.settings.case_body != blank %}
        <div class="rte">{{ section.settings.case_body }}</div>
      {% endif %}
      {% if section.settings.case_link_label != blank %}
        <a
          class="artly-ai__text-link"
          {% if section.settings.case_link == blank %}
            role="link"
            aria-disabled="true"
          {% else %}
            href="{{ section.settings.case_link }}"
          {% endif %}
        >
          {{ section.settings.case_link_label | escape }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="artly-ai__band artly-ai__band--logos">
    <div class="artly-ai__rail artly-ai__logos">
      {% if section.settings.logos_heading != blank %}
        <h2>{{ section.settings.logos_heading | escape }}</h2>
      {% endif %}
      <ul class="artly-ai__logo-list" role="list" aria-label="{{ section.settings.logos_heading | default: 'Trusted by' | escape }}">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <li class="artly-ai__logo-item" {{ block.shopify_attributes }}>
              {% if block.settings.logo_image != blank %}
                {{
                  block.settings.logo_image
                  | image_url: width: 520
                  | image_tag:
                    width: block.settings.logo_image.width,
                    widths: '180, 260, 360, 520',
                    height: block.settings.logo_image.height,
                    alt: block.settings.logo_alt_text,
                    loading: 'lazy',
                    class: 'artly-ai__logo-image'
                }}
              {% else %}
                <span>{{ block.settings.logo_name | escape }}</span>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__team">
    <div class="artly-ai__section-intro artly-ai__section-intro--center">
      {% if section.settings.team_heading != blank %}
        <h2>{{ section.settings.team_heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="artly-ai__team-grid">
      {% for block in section.blocks %}
        {% if block.type == 'team_member' %}
          <article class="artly-ai__team-card" {{ block.shopify_attributes }}>
            <div class="artly-ai__team-image">
              {% if block.settings.image != blank %}
                {% assign team_alt = block.settings.image_alt_text | default: block.settings.name %}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    width: block.settings.image.width,
                    widths: '320, 480, 640, 900',
                    height: block.settings.image.height,
                    alt: team_alt,
                    loading: 'lazy',
                    class: 'artly-ai__media-image'
                }}
              {% else %}
                <svg class="artly-ai__portrait-placeholder" viewBox="0 0 420 320" role="img" aria-label="{{ block.settings.name | escape }}">
                  <rect width="420" height="320" rx="8" fill="#e0e7eb"/>
                  <circle cx="210" cy="132" r="54" fill="#f7fafb"/>
                  <path d="M118 284c18-62 52-93 92-93s74 31 92 93H118Z" fill="#f7fafb"/>
                </svg>
              {% endif %}
            </div>
            <h3>{{ block.settings.name | escape }}</h3>
            {% if block.settings.bio != blank %}
              <p>{{ block.settings.bio | escape }}</p>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__press">
    <div class="artly-ai__section-intro artly-ai__section-intro--center">
      {% if section.settings.press_heading != blank %}
        <h2>{{ section.settings.press_heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="artly-ai__press-grid">
      {% for block in section.blocks %}
        {% if block.type == 'press_item' %}
          <article class="artly-ai__press-card" {{ block.shopify_attributes }}>
            {% if block.settings.source != blank %}
              <p class="artly-ai__press-source">{{ block.settings.source | escape }}</p>
            {% endif %}
            <h3>{{ block.settings.heading | escape }}</h3>
            {% if block.settings.body != blank %}
              <p>{{ block.settings.body | escape }}</p>
            {% endif %}
            {% if block.settings.link_label != blank %}
              <a
                class="artly-ai__text-link"
                {% if block.settings.link == blank %}
                  role="link"
                  aria-disabled="true"
                {% else %}
                  href="{{ block.settings.link }}"
                {% endif %}
              >
                {{ block.settings.link_label | escape }}
              </a>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="artly-ai__rail artly-ai__section artly-ai__faq">
    <div class="artly-ai__section-intro artly-ai__section-intro--center">
      {% if section.settings.faq_heading != blank %}
        <h2>{{ section.settings.faq_heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="artly-ai__faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <details class="artly-ai__faq-item" {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question | escape }}</span>
              <span aria-hidden="true">+</span>
            </summary>
            {% if block.settings.answer != blank %}
              <div class="rte">{{ block.settings.answer }}</div>
            {% endif %}
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="artly-ai__band artly-ai__band--closing">
    <div class="artly-ai__rail artly-ai__closing">
      <div class="artly-ai__closing-copy">
        {% if section.settings.closing_heading != blank %}
          <h2>{{ section.settings.closing_heading | escape }}</h2>
        {% endif %}
        {% if section.settings.closing_body != blank %}
          <div class="rte">{{ section.settings.closing_body }}</div>
        {% endif %}
      </div>

      <div class="artly-ai__closing-grid">
        {% for block in section.blocks %}
          {% if block.type == 'cta_tile' %}
            <article class="artly-ai__closing-card" {{ block.shopify_attributes }}>
              <div class="artly-ai__closing-icon" aria-hidden="true">
                {% render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.icon_image,
                  width: 34,
                  class_name: 'artly-ai__closing-icon-svg'
                %}
              </div>
              <h3>{{ block.settings.heading | escape }}</h3>
              {% if block.settings.body != blank %}
                <div class="rte">{{ block.settings.body }}</div>
              {% endif %}
              {% if block.settings.link_label != blank %}
                <a
                  class="artly-ai__text-link"
                  {% if block.settings.link == blank %}
                    role="link"
                    aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.link }}"
                  {% endif %}
                >
                  {{ block.settings.link_label | escape }}
                </a>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .artly-ai-l1 {
    --artly-ai-rail: var(--artly-rail-width, min(1180px, calc(100% - 32px)));
    --artly-ai-section-y: clamp(44px, 7vw, 84px);
    --artly-ai-section-y-tight: clamp(32px, 5vw, 60px);
    --artly-ai-card-bg: rgba(255, 255, 255, 0.92);
    --artly-ai-card-border: 1px solid rgba(106, 118, 128, 0.24);
    overflow-x: clip;
    color: var(--artly-ink);
    background: transparent;
  }

  .artly-ai__rail {
    width: var(--artly-ai-rail);
    max-width: var(--artly-ai-rail);
    margin-inline: auto;
  }

  .artly-ai__hero {
    padding-block: clamp(52px, 8vw, 94px) clamp(28px, 5vw, 52px);
  }

  .artly-ai__hero-inner {
    display: grid;
    gap: clamp(20px, 3vw, 34px);
    justify-items: center;
    text-align: center;
  }

  .artly-ai__hero-heading {
    max-width: 950px;
    margin: 0;
    color: var(--artly-ink);
    font-family: var(--artly-font-heading);
    font-size: clamp(2.2rem, 5.2vw, 4.65rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.03;
  }

  .artly-ai__hero-body,
  .artly-ai__section-intro .rte,
  .artly-ai__cta-body,
  .artly-ai__case-copy .rte,
  .artly-ai__closing-copy .rte,
  .artly-ai__how-cta .rte {
    color: var(--artly-steel);
    font-size: 1rem;
    line-height: 1.62;
  }

  .artly-ai__hero-body {
    max-width: 900px;
  }

  .artly-ai__hero-body p,
  .artly-ai__section-intro p,
  .artly-ai__cta-body p,
  .artly-ai__case-copy p,
  .artly-ai__closing-copy p,
  .artly-ai__how-cta p,
  .artly-ai__advantage-card p,
  .artly-ai__step p,
  .artly-ai__faq-item p,
  .artly-ai__closing-card p {
    margin: 0;
  }

  .artly-ai__stat-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .artly-ai__stat {
    min-height: 76px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 14px;
    border: var(--artly-ai-card-border);
    border-radius: var(--artly-radius);
    background: var(--artly-ai-card-bg);
    text-align: left;
  }

  .artly-ai__stat-icon-wrap,
  .artly-ai__advantage-icon,
  .artly-ai__closing-icon {
    display: grid;
    place-items: center;
    border-radius: 7px;
    background: color-mix(in srgb, var(--artly-robotics-blue) 36%, white);
    color: var(--artly-signal-dark);
  }

  .artly-ai__stat-icon-wrap {
    width: 40px;
    height: 40px;
  }

  .artly-ai__stat-icon {
    width: 22px;
    height: 22px;
  }

  .artly-ai__stat-content {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .artly-ai__stat strong {
    color: var(--artly-ink);
    font-size: 1rem;
    line-height: 1.15;
  }

  .artly-ai__stat span span {
    color: var(--artly-steel);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .artly-ai__hero-cta {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    padding-top: clamp(16px, 3vw, 34px);
    text-align: left;
  }

  .artly-ai__hero-cta-copy {
    display: grid;
    gap: 8px;
  }

  .artly-ai__cta-heading {
    margin: 0;
    color: var(--artly-ink);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 850;
    line-height: 1.18;
  }

  .artly-ai__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .artly-ai__band {
    width: 100%;
  }

  .artly-ai__band--demo,
  .artly-ai__band--logos,
  .artly-ai__band--closing {
    background:
      linear-gradient(90deg, rgba(247, 250, 251, 0.94), rgba(238, 244, 247, 0.96)),
      repeating-linear-gradient(90deg, rgba(185, 220, 229, 0.12) 0 12px, rgba(185, 220, 229, 0.04) 12px 26px);
  }

  .artly-ai__demo {
    display: grid;
    gap: clamp(22px, 3vw, 34px);
    padding-block: var(--artly-ai-section-y);
    justify-items: center;
  }

  .artly-ai__section {
    padding-block: var(--artly-ai-section-y);
  }

  .artly-ai__section-intro {
    display: grid;
    gap: 12px;
    max-width: 760px;
  }

  .artly-ai__section-intro--center {
    margin-inline: auto;
    justify-items: center;
    text-align: center;
  }

  .artly-ai__section-intro h2,
  .artly-ai__case-copy h2,
  .artly-ai__closing-copy h2 {
    margin: 0;
    color: var(--artly-ink);
    font-family: var(--artly-font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .artly-ai__video-shell,
  .artly-ai__image-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(106, 118, 128, 0.2);
    border-radius: var(--artly-radius);
    background: #dce3e8;
  }

  .artly-ai__video-shell {
    width: min(840px, 100%);
    aspect-ratio: 16 / 9;
    box-shadow: var(--artly-shadow-panel);
  }

  .artly-ai__external-video,
  .artly-ai__external-video iframe,
  .artly-ai__external-video video,
  .artly-ai__external-video img,
  .artly-ai__media-image,
  .artly-ai__media-placeholder,
  .artly-ai__image-placeholder,
  .artly-ai__portrait-placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  .artly-ai__external-video iframe,
  .artly-ai__external-video video,
  .artly-ai__external-video img,
  .artly-ai__media-image {
    object-fit: cover;
  }

  .artly-ai__advantage {
    display: grid;
    gap: clamp(26px, 4vw, 42px);
  }

  .artly-ai__advantage-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 32px;
  }

  .artly-ai__advantage-card {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 14px;
    align-items: start;
    min-height: 150px;
  }

  .artly-ai__advantage-icon {
    width: 44px;
    height: 44px;
  }

  .artly-ai__advantage-icon-svg,
  .artly-ai__closing-icon-svg {
    width: 34px;
    height: 34px;
  }

  .artly-ai__advantage-card h3,
  .artly-ai__step h3,
  .artly-ai__how-cta h3,
  .artly-ai__team-card h3,
  .artly-ai__press-card h3,
  .artly-ai__closing-card h3 {
    margin: 0;
    color: var(--artly-ink);
    font-size: clamp(1.02rem, 1.5vw, 1.2rem);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.2;
  }

  .artly-ai__advantage-card .rte,
  .artly-ai__step .rte,
  .artly-ai__closing-card .rte {
    margin-top: 9px;
    color: var(--artly-steel);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .artly-ai__how,
  .artly-ai__case {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
    gap: clamp(30px, 6vw, 74px);
    align-items: center;
  }

  .artly-ai__how-content {
    display: grid;
    gap: 24px;
  }

  .artly-ai__steps-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px 24px;
  }

  .artly-ai__step {
    display: grid;
    gap: 8px;
  }

  .artly-ai__step-number {
    margin: 0;
    color: var(--artly-signal-dark);
    font-weight: 900;
    line-height: 1;
  }

  .artly-ai__how-cta {
    display: grid;
    gap: 12px;
    justify-items: start;
    max-width: 620px;
    padding-top: 6px;
  }

  .artly-ai__image-panel {
    aspect-ratio: 1 / 1;
    box-shadow: none;
  }

  .artly-ai__case {
    grid-template-columns: minmax(320px, 0.94fr) minmax(0, 1fr);
    padding-block-start: var(--artly-ai-section-y-tight);
  }

  .artly-ai__case .artly-ai__image-panel {
    aspect-ratio: 1.25 / 1;
  }

  .artly-ai__case-copy {
    display: grid;
    gap: 14px;
    max-width: 620px;
  }

  .artly-ai__eyebrow,
  .artly-ai__press-source {
    margin: 0;
    color: var(--artly-signal-dark);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .artly-ai__text-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--artly-signal-dark);
    font-weight: 850;
    text-decoration: none;
  }

  .artly-ai__text-link::after {
    content: "->";
    font-weight: 850;
  }

  .artly-ai__text-link:hover,
  .artly-ai__text-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .artly-ai__logos {
    display: grid;
    gap: 20px;
    justify-items: center;
    padding-block: 34px;
  }

  .artly-ai__logos h2 {
    margin: 0;
    color: var(--artly-steel);
    font-size: 0.9rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .artly-ai__logo-list {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 20px 34px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .artly-ai__logo-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 92px;
    min-height: 38px;
    color: var(--artly-steel);
    font-weight: 850;
    opacity: 0.78;
  }

  .artly-ai__logo-image {
    display: block;
    width: auto;
    max-width: 154px;
    height: 30px;
    object-fit: contain;
    filter: grayscale(1) saturate(0.8);
  }

  .artly-ai__team,
  .artly-ai__press,
  .artly-ai__faq {
    display: grid;
    gap: clamp(24px, 4vw, 42px);
  }

  .artly-ai__team-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .artly-ai__team-card {
    display: grid;
    gap: 10px;
    text-align: center;
  }

  .artly-ai__team-image {
    aspect-ratio: 1.22 / 1;
    overflow: hidden;
    border-radius: var(--artly-radius);
    background: #e0e7eb;
  }

  .artly-ai__team-card p,
  .artly-ai__press-card p {
    margin: 0;
    color: var(--artly-steel);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .artly-ai__press-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .artly-ai__press-card,
  .artly-ai__closing-card {
    display: grid;
    align-content: start;
    gap: 12px;
    min-height: 180px;
    padding: clamp(18px, 2.2vw, 24px);
    border: var(--artly-ai-card-border);
    border-radius: var(--artly-radius);
    background: var(--artly-ai-card-bg);
  }

  .artly-ai__faq-list {
    display: grid;
    gap: 10px;
    width: min(820px, 100%);
    margin-inline: auto;
  }

  .artly-ai__faq-item {
    border: 1px solid rgba(106, 118, 128, 0.24);
    border-radius: var(--artly-radius);
    background: rgba(255, 255, 255, 0.84);
  }

  .artly-ai__faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 52px;
    padding: 14px 18px;
    color: var(--artly-ink);
    cursor: pointer;
    font-weight: 800;
    line-height: 1.25;
    list-style: none;
  }

  .artly-ai__faq-item summary::-webkit-details-marker {
    display: none;
  }

  .artly-ai__faq-item[open] summary span:last-child {
    transform: rotate(45deg);
  }

  .artly-ai__faq-item summary span:last-child {
    transition: transform 160ms ease;
  }

  .artly-ai__faq-item .rte {
    padding: 0 18px 18px;
    color: var(--artly-steel);
    line-height: 1.6;
  }

  .artly-ai__closing {
    display: grid;
    grid-template-columns: minmax(220px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(28px, 5vw, 68px);
    align-items: start;
    padding-block: var(--artly-ai-section-y);
  }

  .artly-ai__closing-copy {
    display: grid;
    gap: 12px;
  }

  .artly-ai__closing-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .artly-ai__closing-icon {
    width: 44px;
    height: 44px;
  }

  @media screen and (max-width: 1090px) {
    .artly-ai__stat-grid,
    .artly-ai__press-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .artly-ai__how,
    .artly-ai__case,
    .artly-ai__closing {
      grid-template-columns: 1fr;
    }

    .artly-ai__case .artly-ai__image-panel {
      order: 2;
    }
  }

  @media screen and (max-width: 749px) {
    .artly-ai-l1 {
      --artly-ai-rail: var(--artly-rail-width, calc(100% - 32px));
      --artly-ai-section-y: 42px;
      --artly-ai-section-y-tight: 30px;
    }

    .artly-ai__hero {
      padding-block-start: 42px;
    }

    .artly-ai__hero-heading {
      font-size: clamp(2rem, 10vw, 3.1rem);
    }

    .artly-ai__hero-cta {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .artly-ai__actions {
      justify-content: stretch;
      width: 100%;
    }

    .artly-ai__actions .artly-button,
    .artly-ai__how-cta .artly-button {
      width: 100%;
    }

    .artly-ai__stat-grid,
    .artly-ai__advantage-grid,
    .artly-ai__steps-grid,
    .artly-ai__team-grid,
    .artly-ai__press-grid,
    .artly-ai__closing-grid {
      grid-template-columns: 1fr;
    }

    .artly-ai__advantage-card {
      min-height: auto;
    }

    .artly-ai__image-panel {
      aspect-ratio: 1 / 0.78;
    }

    .artly-ai__case .artly-ai__image-panel {
      aspect-ratio: 1 / 0.78;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .artly-ai__faq-item summary span:last-child {
      transition: none;
    }
  }
{% endstylesheet %}

