{% liquid
  assign closing_primary_label = ''
  assign closing_primary_link = blank

  for closing_block in section.blocks
    if closing_primary_label == blank
      if closing_block.settings.link_label != blank
        assign closing_primary_label = closing_block.settings.link_label
        assign closing_primary_link = closing_block.settings.link
      endif
    endif
  endfor
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style artly-system artly-ai-l1 artly-ai__band artly-ai__band--closing"
  aria-labelledby="ArtlyAiClosingTitle-{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  <div class="artly-ai__rail artly-ai__closing">
    <div class="artly-ai__closing-copy">
      {% if section.settings.closing_heading != blank %}
        <h2 id="ArtlyAiClosingTitle-{{ section.id }}">{{ section.settings.closing_heading | escape }}</h2>
      {% endif %}
      {% if section.settings.closing_body != blank %}
        <div class="rte">{{ section.settings.closing_body }}</div>
      {% endif %}
      {% if closing_primary_label != blank %}
        {% if closing_primary_link != blank %}
          <a class="artly-button artly-button--primary artly-ai__closing-primary-link" href="{{ closing_primary_link }}">
            {{ closing_primary_label | escape }}
          </a>
        {% else %}
          <span
            class="artly-button artly-button--primary artly-ai__closing-primary-link artly-ai__closing-primary-link--disabled"
          >
            {{ closing_primary_label | escape }}
          </span>
        {% endif %}
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="artly-ai__closing-grid">
        {% for block in section.blocks %}
          <article class="artly-ai__closing-card" {{ block.shopify_attributes }}>
            <div class="artly-ai__closing-icon" aria-hidden="true">
              {% render 'icon-or-image',
                icon: block.settings.icon,
                image_upload: block.settings.icon_image,
                width: 34,
                class_name: 'artly-ai__closing-icon-svg'
              %}
            </div>
            <h3>{{ block.settings.heading | escape }}</h3>
            {% if block.settings.body != blank %}
              <div class="rte">{{ block.settings.body }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Artly AI catch-all CTA",
  "class": "artly-ai-catch-all-section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "closing_heading",
      "label": "Heading",
      "default": "Believe in what we're building?"
    },
    {
      "type": "richtext",
      "id": "closing_body",
      "label": "Body",
      "default": "<p>Join Artly as we build the core training layer for commercial physical AI.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "cta_tile",
      "name": "Closing CTA tile",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lightning_bolt", "label": "Lightning" },
            { "value": "hand", "label": "Hand" },
            { "value": "world", "label": "World" },
            { "value": "check_box", "label": "Checklist" },
            { "value": "flywheel", "label": "Flywheel" }
          ],
          "default": "lightning_bolt"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact Us"
        },
        {
          "type": "inline_richtext",
          "id": "body",
          "label": "Body",
          "default": "Talk with our team about a custom robot training project."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Artly AI catch-all CTA"
    }
  ]
}
{% endschema %}
