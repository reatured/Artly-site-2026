{% liquid
  assign block_settings = block.settings
  assign logo_name = block_settings.logo_name | default: 'Trusted logo'
  assign logo_alt_text = block_settings.logo_alt_text | default: logo_name
  assign logo_image = block_settings.logo_image
  assign external_image_url = block_settings.external_image_url
  assign logo_url = block_settings.logo_url
  assign logo_height = block_settings.display_height | default: section.settings.logo_height
  assign open_in_new_tab = section.settings.open_in_new_tab

  case block_settings.open_in_new_tab
    when 'on'
      assign open_in_new_tab = true
    when 'off'
      assign open_in_new_tab = false
  endcase

  assign aria_label = logo_name | default: 'Trusted logo'
%}

{% if logo_url != blank %}
  <li class="trusted-by-logo-strip__item">
    <a
      class="trusted-by-logo-strip__link"
      href="{{ logo_url }}"
      aria-label="{{ aria_label | escape }}"
      style="--trusted-by-logo-height: {{ logo_height }}px;"
      {{ block.shopify_attributes }}
      {% if open_in_new_tab %}
        target="_blank"
        rel="noopener noreferrer"
      {% endif %}
    >
      {% if logo_image != blank %}
        {{
          logo_image
          | image_url: width: 1200
          | image_tag:
            width: logo_image.width,
            widths: '240, 360, 480, 640, 768, 960, 1200',
            height: logo_image.height,
            alt: logo_alt_text,
            class: 'trusted-by-logo-strip__image',
            loading: 'lazy',
            sizes: '(min-width: 750px) 180px, 150px'
        }}
      {% elsif external_image_url != blank %}
        <img src="{{ external_image_url | escape }}" alt="{{ logo_alt_text | escape }}" class="trusted-by-logo-strip__image" loading="lazy" width="160" height="{{ logo_height }}">
      {% else %}
        <span class="trusted-by-logo-strip__fallback">{{ logo_name }}</span>
      {% endif %}
    </a>
  </li>
{% else %}
  <li class="trusted-by-logo-strip__item">
    <span
      class="trusted-by-logo-strip__logo"
      style="--trusted-by-logo-height: {{ logo_height }}px;"
      {{ block.shopify_attributes }}
    >
      {% if logo_image != blank %}
        {{
          logo_image
          | image_url: width: 1200
          | image_tag:
            width: logo_image.width,
            widths: '240, 360, 480, 640, 768, 960, 1200',
            height: logo_image.height,
            alt: logo_alt_text,
            class: 'trusted-by-logo-strip__image',
            loading: 'lazy',
            sizes: '(min-width: 750px) 180px, 150px'
        }}
      {% elsif external_image_url != blank %}
        <img src="{{ external_image_url | escape }}" alt="{{ logo_alt_text | escape }}" class="trusted-by-logo-strip__image" loading="lazy" width="160" height="{{ logo_height }}">
      {% else %}
        <span class="trusted-by-logo-strip__fallback">{{ logo_name }}</span>
      {% endif %}
    </span>
  </li>
{% endif %}

{% stylesheet %}
  .trusted-by-logo-strip__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trusted-by-logo-strip__link,
  .trusted-by-logo-strip__logo {
    min-height: 36px;
    min-width: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem 0.45rem;
    color: inherit;
    text-decoration: none;
    border-radius: 4px;
    text-align: center;
    width: fit-content;
    max-width: 11rem;
  }

  .trusted-by-logo-strip__logo {
    color: var(--color-foreground);
    pointer-events: none;
  }

  .trusted-by-logo-strip__link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .trusted-by-logo-strip__image {
    display: block;
    height: var(--trusted-by-logo-height);
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: saturate(0.96);
  }

  .trusted-by-logo-strip__fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--trusted-by-logo-height);
    font-size: 0.85rem;
    color: var(--color-foreground-muted);
    border: 1px dashed var(--color-border);
    border-radius: 6px;
    padding: 0 0.55rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trusted logo",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "external_image_url",
      "label": "External image URL",
      "info": "Use when the logo is hosted outside Shopify. Overrides the image picker if set."
    },
    {
      "type": "text",
      "id": "logo_name",
      "label": "Logo name",
      "default": "Brand logo"
    },
    {
      "type": "url",
      "id": "logo_url",
      "label": "Logo link"
    },
    {
      "type": "text",
      "id": "logo_alt_text",
      "label": "Logo alt text",
      "default": "Brand logo"
    },
    {
      "type": "range",
      "id": "display_height",
      "label": "Display height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "open_in_new_tab",
      "label": "Open logo link in new tab",
      "options": [
        {
          "value": "inherit",
          "label": "Use section default"
        },
        {
          "value": "on",
          "label": "Open in new tab"
        },
        {
          "value": "off",
          "label": "Open in same tab"
        }
      ],
      "default": "inherit"
    }
  ]
}
{% endschema %}
