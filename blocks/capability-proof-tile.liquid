{%- liquid
  assign tile_settings = block.settings
%}
{% assign show_media = false %}
{% if tile_settings.icon != 'none' or tile_settings.image != blank %}
  {% assign show_media = true %}
{% endif %}

{% assign show_stat = false %}
{% if tile_settings.stat_value != blank or tile_settings.stat_label != blank %}
  {% assign show_stat = true %}
{% endif %}

{% if tile_settings.link != blank %}
  <a
    href="{{ tile_settings.link }}"
    class="capability-proof-tile capability-proof-tile--link"
    {% if tile_settings.open_in_new_tab %}
      target="_blank" rel="noopener"
    {% endif %}
    {{ block.shopify_attributes }}
  >
{% else %}
  <article class="capability-proof-tile" {{ block.shopify_attributes }}>
{% endif %}
  {% if show_media %}
    <div class="capability-proof-tile__media">
      {% render 'icon-or-image',
        icon: tile_settings.icon,
        image_upload: tile_settings.image,
        width: section.settings.icon_size,
        class_name: 'capability-proof-tile__icon',
        attributes: 'aria-hidden="true"'
      %}
    </div>
  {% endif %}

  <div class="capability-proof-tile__content">
    <h3 class="capability-proof-tile__title">{{ tile_settings.heading }}</h3>

    {% if tile_settings.body != blank %}
      <div class="capability-proof-tile__body rte">
        {{ tile_settings.body }}
      </div>
    {% endif %}

    {% if show_stat %}
      <div class="capability-proof-tile__stat">
        {% if tile_settings.stat_value != blank %}
          <p class="capability-proof-tile__stat-value">{{ tile_settings.stat_value }}</p>
        {% endif %}
        {% if tile_settings.stat_label != blank %}
          <p class="capability-proof-tile__stat-label">{{ tile_settings.stat_label }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>

{% if tile_settings.link != blank %}
  </a>
{% else %}
  </article>
{% endif %}

{% stylesheet %}
  .capability-proof-tile {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    padding: 18px;
    min-height: 100%;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 16px;
    color: var(--color-foreground);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .capability-proof-tile--link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    text-decoration: none;
  }

  .capability-proof-tile--link:hover {
    border-color: var(--color-foreground-muted);
    box-shadow: 0 8px 20px rgb(0 0 0 / 0.05);
  }

  .capability-proof-tile__media {
    display: flex;
    align-items: center;
    min-height: calc(var(--capability-proof-icon-size, 40px) + 4px);
  }

  .capability-proof-tile__icon {
    width: var(--capability-proof-icon-size, 40px);
    height: var(--capability-proof-icon-size, 40px);
    color: var(--color-foreground);
    fill: currentColor;
    display: block;
  }


  .capability-proof-tile__content {
    display: grid;
    gap: 12px;
  }

  .capability-proof-tile__title {
    margin: 0;
    font-size: var(--font-h6--size);
    line-height: var(--font-h6--line-height);
  }

  .capability-proof-tile__body {
    margin: 0;
    color: var(--color-foreground-muted);
  }

  .capability-proof-tile__body p {
    margin: 0;
  }

  .capability-proof-tile__stat {
    margin-top: auto;
  }

  .capability-proof-tile__stat-value {
    margin: 0;
    font-size: var(--font-h5--size);
    line-height: 1.2;
    font-weight: 600;
  }

  .capability-proof-tile__stat-label {
    margin: 6px 0 0;
    color: var(--color-foreground-muted);
    font-size: var(--font-caption--size);
    line-height: 1.4;
  }

  .capability-proof-tile__stat-label:first-of-type {
    margin-top: 0;
  }

  .capability-proof-tile--link {
    color: inherit;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Capability proof tile",
  "class": "capability-proof-tile-block",
  "settings": [
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "stopwatch",
          "label": "Stopwatch"
        },
        {
          "value": "recycle",
          "label": "Recycle"
        },
        {
          "value": "truck",
          "label": "Truck"
        },
        {
          "value": "plant",
          "label": "Plant"
        },
        {
          "value": "lightning_bolt",
          "label": "Lightning"
        },
        {
          "value": "check_box",
          "label": "Checklist"
        },
        {
          "value": "iron",
          "label": "Iron"
        }
      ],
      "default": "stopwatch"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (optional)",
      "info": "If set, this replaces the icon."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Tile heading",
      "default": "Capability tile"
    },
    {
      "type": "inline_richtext",
      "id": "body",
      "label": "Tile body",
      "default": "Define what this tile proves and the context for that proof."
    },
    {
      "type": "text",
      "id": "stat_value",
      "label": "Stat value",
      "default": "0"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Stat label",
      "default": "metric"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional tile link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Capability proof tile",
      "category": "Tiles"
    }
  ]
}
{% endschema %}
