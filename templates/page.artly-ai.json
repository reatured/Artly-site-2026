        "faq-what": {
          "type": "faq_item",
          "settings": {
            "question": "What is Artly AI?",
            "answer": "<p>Artly AI is a robot training platform that captures expert demonstrations and converts them into deployment-ready robot behavior.</p>"
          }
        },
        "faq-code": {
          "type": "faq_item",
          "settings": {
            "question": "Do we need to write code to train a robot?",
            "answer": "<p>No. Artly AI is built around no-code imitation learning, where expert demonstrations become the training signal for the robot.</p>"
          }
        },
        "faq-time": {
          "type": "faq_item",
          "settings": {
            "question": "How long does training take?",
            "answer": "<p>Some tasks can be trained in as little as 30 minutes, depending on task complexity, deployment environment, and required validation.</p>"
          }
        },
        "faq-custom": {
          "type": "faq_item",
          "settings": {
            "question": "Can Artly AI support custom operations?",
            "answer": "<p>Yes. Each deployment is scoped around the customer's operation, environment, domain expert, and automation goals.</p>"
          }
        },
        "faq-data": {
          "type": "faq_item",
          "settings": {
            "question": "What kind of data does Artly AI use?",
            "answer": "<p>Artly AI uses real-world data from live deployments and expert demonstrations instead of relying only on simulation.</p>"
          }
        },
        "faq-precision": {
          "type": "faq_item",
          "settings": {
            "question": "What tasks are a good fit?",
            "answer": "<p>Artly AI is designed for precise, repeatable, multi-step tasks where expert craft and consistency matter.</p>"
          }
        },
        "faq-deployment": {
          "type": "faq_item",
          "settings": {
            "question": "What happens after deployment?",
            "answer": "<p>Artly supports deployment and ongoing performance, including monitoring for anomalies and opportunities to improve robot behavior.</p>"
          }
        }
      },
