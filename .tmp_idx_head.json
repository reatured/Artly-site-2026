    "platform_overview": {
      "type": "platform-overview",
      "settings": {
        "eyebrow": "The Artly Ecosystem",
        "heading": "Automation built for the real world.",
        "body_line_1": "At Artly, we believe the future belongs to everyone, and everyone belongs in it. We’re on a mission to give everyone, regardless of technical background, the ability to teach, deploy, and benefit from the next generation of intelligent technology.",
        "body_line_2": "Our patented physical AI platform combines proprietary hardware, deep learning + Vision-Language-Action models, and a real-world deployment feedback loop to deliver custom specialized robots at commercial scale — without the steep learning curve.",
        "proof_microcopy": "Evidence markers: Expert-taught tasks | Real-world deployment feedback | Deployable hardware stack",
        "primary_cta_label": "Talk to an Expert",
        "primary_cta_open_in_new_tab": false,
        "primary_cta_style": "button",
        "secondary_cta_label": "Learn More",
        "secondary_cta_open_in_new_tab": false,
        "secondary_cta_style": "link",
        "media_type": "video",
        "media_position": "left",
        "media_width": "wide",
        "media_height": "60svh",
        "media_alt_text": "Artly robotic workcell demonstrating service automation on a commercial counter",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 32,
        "padding-block-end": 32
      }
    },
